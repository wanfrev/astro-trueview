---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import TheFails from '../components/TheFails.astro';
import LabTesting from '../components/LabTesting.astro';
import GoodAndBad from '../components/GoodAndBad.astro';
import Features from '../components/Features.astro';
import WaitTheresMore from '../components/WaitTheresMore.astro';
import FinalSearch from '../components/FinalSearch.astro';
import GoodAndBadfirst from '../components/GoodAndBadfirst.astro';
---

<Layout title="Trueview | Science over Opinion">
	<Navbar />

	<main>
		<Hero />
		<Stats />
		<TheFails />
		<!-- Espacio extra entre secciones para separación visual -->
		<div class="py-12 md:py-20" aria-hidden="true"></div>
		<LabTesting />
		<div class="py-12 md:py-20" aria-hidden="true"></div>
		<GoodAndBadfirst />
		<Features client:load />
		<GoodAndBad />
		<WaitTheresMore />
		<FinalSearch />
	</main>
</Layout>
