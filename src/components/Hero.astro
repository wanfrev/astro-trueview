---
import Union from "../assets/icons/Union.svg";
import Phone from "../assets/images/phonecaution1.png";
import Brands from "../assets/icons/brands.svg";
import { Image } from "astro:assets";

// Aquí importarás tus SVGs de marcas cuando los tengas listos
// import Logo1 from "../assets/logos/logo1.svg";

// Usamos un único SVG con todas las marcas
const topBrandLogos = Brands;
---

<section
  data-hero-root
  data-hero-in-view="false"
  data-bg="hero"
  class="hero-root section-shell relative min-h-screen flex items-center pt-24 sm:pt-28 md:pt-32 lg:pt-36 pb-12 md:pb-20 overflow-hidden"
>
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div
      class="hidden"
    >
    </div>
    <div
      class="hidden"
    >
    </div>
    <div
      class="hidden"
    >
    </div>
  </div>

  <div class="content-shell hero-layout w-full items-center gap-10 lg:gap-8">
    <div data-hero-copy class="hero-copy text-center lg:text-left z-10">
      <h1
        id="hero-title"
        class="hero-reveal hero-reveal-copy-1 mx-auto max-w-[22ch] text-4xl sm:text-5xl lg:text-[52px] xl:text-[64px] 2xl:text-[70px] font-bold leading-[0.98] lg:leading-[0.95] tracking-[-0.03em] text-white lg:mx-0"
      >
        The only marketplace where every product is lab tested
      </h1>

      <p
        class="hero-reveal hero-reveal-copy-2 mt-6 lg:mt-10 text-base sm:text-lg lg:text-[19px] xl:text-xl text-white/60 max-w-[56ch] font-medium leading-normal lg:leading-[1.4] tracking-tight mx-auto lg:mx-0"
      >
        We don’t offer you an opinion, we just show you the science.
        <br class="hidden lg:block" />
        If a product passes or fails we show you readable lab results.
        <br class="hidden lg:block" />
        Make healthy decisions, quickly.
      </p>

      <div class="mt-8 lg:mt-12 flex justify-center lg:justify-start">
        <button
          class="hero-reveal hero-reveal-copy-3 w-48 h-15 bg-[#2563eb] hover:brightness-105 rounded-full font-bold text-base text-white flex items-center justify-center transition-all shadow-[0_15px_40px_rgba(37,99,235,0.45)] border border-white/10 leading-none hover:scale-105 active:scale-95"
        >
          Search products
        </button>
      </div>
    </div>

    <div data-hero-media class="hero-media">
      <div class="phone-collage-wrapper">
        <Image
          src={Union}
          alt=""
          aria-hidden="true"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="hero-union-shape"
        />

        <div class="hero-phone-layer hero-reveal hero-reveal-phone">
          <div class="hero-phone-frame">
            <Image
              src={Phone}
              alt="phone caution"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="hero-phone-image"
            />
          </div>
        </div>

        <div data-hero-card="1" class="hero-card-layer hero-reveal hero-reveal-card-1 hero-over-limit-card">
          <div class="hero-over-limit-card-inner">
            <span class="hero-over-limit-value">239.00%</span>
            <span class="hero-over-limit-label">Over Limit</span>
          </div>
        </div>

        <div data-hero-card="2" class="hero-card-layer hero-reveal hero-reveal-card-2 hero-brands-card">
          <div class="hero-brands-card-inner">
            <div class="hero-brands-card-copy">
              <h3 class="hero-brands-title">100+</h3>
              <p class="hero-brands-label">Hundreds of top brands</p>
            </div>

            <div class="hero-brands-logo-slot">
              <Image
                src={topBrandLogos}
                alt="Brands"
                loading="eager"
                decoding="async"
                class="hero-brands-logo"
              />
            </div>
          </div>
        </div>

        <div data-hero-card="3" class="hero-card-layer hero-reveal hero-reveal-card-3 hero-lead-card">
          <div class="hero-lead-card-inner">
            <div class="hero-lead-copy">
              <div class="hero-lead-badge">
                <svg class="hero-lead-badge-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </div>
              <div class="hero-lead-text">
                <span class="hero-lead-title">Lead</span>
                <span class="hero-lead-limit">Limit: 0.5 (ppm)</span>
                <div class="hero-lead-detection">
                  <span class="hero-lead-value">1.77</span>
                  <span class="hero-lead-detected">ppm Detected</span>
                </div>
              </div>
            </div>

            <div class="hero-lead-ratio">
              <span class="hero-lead-ratio-value">230.00%</span>
              <span class="hero-lead-ratio-label">over limit</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-root {
    --hero-copy-y: 0px;
    --hero-copy-opacity: 1;
    --hero-media-y: 0px;
    --hero-card-1-y: 0px;
    --hero-card-2-y: 0px;
    --hero-card-3-y: 0px;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: center;
  }

  .hero-copy {
    transform: translate3d(0, var(--hero-copy-y), 0);
    opacity: var(--hero-copy-opacity);
    will-change: transform, opacity;
    text-align: center;
  }

  .hero-media {
    display: flex;
    justify-content: flex-end;
    min-width: 0;
  }

  @media (min-width: 1025px) {
    .hero-copy {
      order: 2;
    }

    .hero-media {
      order: 1;
      justify-content: flex-start;
    }
  }

  .phone-collage-wrapper {
    position: relative;
    width: 100%;
    max-width: 45rem;
    aspect-ratio: 36 / 26;
    margin-inline: auto;
  }

  .hero-union-shape {
    position: absolute;
    left: 2%;
    top: 1.5%;
    width: 75%;
    max-width: 93%;
    height: auto;
    opacity: 0.4;
    pointer-events: none;
    user-select: none;
    object-fit: contain;
  }

  .hero-phone-layer {
    position: absolute;
    left: 10%;
    top: 0;
    width: 49%;
    height: 100%;
    transform: translate3d(0, calc(var(--hero-media-y) + var(--hero-reveal-offset, 28px)), 0);
    will-change: transform;
  }

  .hero-phone-frame {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hero-phone-image {
    position: absolute;
    left: -12%;
    top: -13.81%;
    width: 143.69%;
    height: 127.66%;
    max-width: none;
    object-fit: contain;
  }

  .hero-card-layer {
    position: absolute;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .hero-card-layer[data-hero-card="1"] {
    left: 13%;
    top: 4.25%;
    width: 18.6%;
    aspect-ratio: 33.5 / 17;
    transform: translate3d(0, calc(var(--hero-card-1-y) + var(--hero-reveal-offset, 28px)), 0);
  }

  .hero-card-layer[data-hero-card="2"] {
    right: 30%;
    top: 30%;
    width: 21.7%;
    aspect-ratio: 39 / 29.5;
    transform: translate3d(0, calc(var(--hero-card-2-y) + var(--hero-reveal-offset, 28px)), 0);
  }

  .hero-card-layer[data-hero-card="3"] {
    left: 3%;
    bottom: 14%;
    width: 26.4%;
    aspect-ratio: 55 / 17.5;
    transform: translate3d(0, calc(var(--hero-card-3-y) + var(--hero-reveal-offset, 28px)), 0);
  }

  .hero-over-limit-card-inner {
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    border-radius: 7px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: #5b5570;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.36);
    padding: 0.6rem 0.8rem;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-over-limit-card:hover .hero-over-limit-card-inner {
    transform: translate3d(0, -0.5rem, 0) scale(1.04);
  }

  .hero-over-limit-value {
    color: #ffffff;
    font-size: clamp(0.9rem, 1.45vw, 1.25rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-over-limit-label {
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.38rem, 0.7vw, 0.62rem);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .hero-brands-card-inner {
    height: 100%;
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 26px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: #4d465f;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
    padding: 0.82rem 0.82rem 0.74rem;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-brands-card:hover .hero-brands-card-inner {
    transform: translate3d(0, -0.5rem, 0) scale(1.04);
  }

  .hero-brands-card-copy {
    flex: 0 0 auto;
  }

  .hero-brands-title {
    color: #ffffff;
    font-size: clamp(1.15rem, 2vw, 1.75rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .hero-brands-label {
    margin-top: 0.25rem;
    color: rgba(255, 255, 255, 0.6);
    font-size: clamp(0.34rem, 0.65vw, 0.56rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-brands-logo-slot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-brands-logo {
    width: 100%;
    max-width: 72%;
    height: auto;
    object-fit: contain;
  }

  .hero-lead-card-inner {
    height: 100%;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: #6f6676;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
    padding: 0.28rem 0.28rem 0.28rem 0.34rem;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }

  .hero-lead-card:hover .hero-lead-card-inner {
    transform: translate3d(0, -0.5rem, 0) scale(1.04);
  }

  .hero-lead-copy {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    gap: 0.42rem;
    min-width: 0;
    overflow: hidden;
  }

  .hero-lead-badge {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.95rem;
    aspect-ratio: 1;
    border-radius: 9999px;
    background: #ffeae8;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.08);
  }

  .hero-lead-badge-icon {
    width: 42%;
    height: 42%;
    color: #ff5b5b;
  }

  .hero-lead-text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .hero-lead-title {
    color: #ffffff;
    font-size: clamp(0.62rem, 0.9vw, 0.95rem);
    font-weight: 600;
    line-height: 1.1;
    white-space: nowrap;
  }

  .hero-lead-limit {
    color: rgba(255, 255, 255, 0.6);
    font-size: clamp(0.3rem, 0.52vw, 0.56rem);
    line-height: 1.1;
    margin-top: 0.12rem;
    white-space: nowrap;
  }

  .hero-lead-detection {
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
    margin-top: 0.18rem;
    min-width: 0;
    overflow: hidden;
  }

  .hero-lead-value {
    color: #ff5b5b;
    font-size: clamp(0.62rem, 0.9vw, 0.95rem);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .hero-lead-detected {
    color: rgba(255, 255, 255, 0.7);
    font-size: clamp(0.3rem, 0.52vw, 0.56rem);
    line-height: 1;
    white-space: nowrap;
  }

  .hero-lead-ratio {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 42.5%;
    height: 100%;
    border-radius: 10px;
    background: #ef4444;
    border: 1px solid rgba(248, 113, 113, 0.5);
    box-shadow: 0 5px 15px rgba(238, 95, 95, 0.4);
    padding: 0.22rem 0.35rem;
    min-width: 0;
    overflow: hidden;
  }

  .hero-lead-ratio-value {
    color: #ffffff;
    font-size: clamp(0.62rem, 0.9vw, 0.95rem);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .hero-lead-ratio-label {
    margin-top: 0.14rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.28rem, 0.5vw, 0.56rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }

  .hero-reveal {
    --hero-reveal-offset: 28px;
    opacity: 0;
    transform: translate3d(0, var(--hero-reveal-offset), 0);
    transition-property: opacity, transform;
    transition-duration: 760ms;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-reveal-copy-1 { transition-delay: 60ms; }
  .hero-reveal-copy-2 { transition-delay: 140ms; }
  .hero-reveal-copy-3 { transition-delay: 220ms; }
  .hero-reveal-phone { transition-delay: 120ms; }
  .hero-reveal-card-1 { transition-delay: 200ms; }
  .hero-reveal-card-2 { transition-delay: 260ms; }
  .hero-reveal-card-3 { transition-delay: 320ms; }

  .hero-root[data-hero-in-view="true"] .hero-reveal {
    opacity: 1;
    --hero-reveal-offset: 0px;
  }

  @media (max-width: 1024px) {
    .hero-layout {
      grid-template-columns: 1fr;
      justify-items: center;
    }

    .hero-copy {
      text-align: center;
      justify-self: center;
    }

    .hero-media {
      width: 100%;
      justify-content: center;
    }

    .phone-collage-wrapper {
      max-width: 450px;
    }

    .hero-union-shape {
      left: 50%;
      top: 3%;
      width: 82%;
      transform: translateX(-50%);
    }

    .hero-lead-card-inner {
      gap: 0.32rem;
      padding: 0.24rem 0.22rem 0.24rem 0.26rem;
      border-radius: 16px;
    }

    .hero-lead-copy {
      gap: 0.3rem;
    }

    .hero-lead-badge {
      width: 1.7rem;
    }

    .hero-lead-ratio {
      width: 40%;
      padding: 0.18rem 0.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-copy,
    .hero-phone-layer,
    .hero-card-layer[data-hero-card="1"],
    .hero-card-layer[data-hero-card="2"],
    .hero-card-layer[data-hero-card="3"] {
      transform: none !important;
    }

    .hero-reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const heroes = document.querySelectorAll("[data-hero-root]");

    heroes.forEach((hero) => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      hero.setAttribute("data-hero-in-view", "false");

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              hero.setAttribute("data-hero-in-view", "true");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.28 }
      );

      revealObserver.observe(hero);

      const parallaxEnabled = window.matchMedia("(min-width: 1280px)").matches;

      if (prefersReducedMotion || !parallaxEnabled) {
        hero.style.setProperty("--hero-copy-y", "0px");
        hero.style.setProperty("--hero-copy-opacity", "1");
        hero.style.setProperty("--hero-media-y", "0px");
        hero.style.setProperty("--hero-card-1-y", "0px");
        hero.style.setProperty("--hero-card-2-y", "0px");
        hero.style.setProperty("--hero-card-3-y", "0px");
        return;
      }

      let rafId = 0;
      const onScroll = () => {
        if (rafId !== 0) {
          return;
        }

        rafId = window.requestAnimationFrame(() => {
          rafId = 0;

          const rect = hero.getBoundingClientRect();
          const isDesktop = window.matchMedia("(min-width: 1024px)").matches;

          // Start parallax only after the hero begins leaving the top of the viewport.
          const scrolledPastTop = Math.max(0, -rect.top);
          const travelDistance = rect.height * (isDesktop ? 0.72 : 0.55);
          const progress = clamp(scrolledPastTop / Math.max(travelDistance, 1), 0, 1);

          const copyDistance = isDesktop ? 124 : 70;
          const mediaDistance = isDesktop ? 46 : 26;
          const copyY = -progress * copyDistance;
          const mediaY = -progress * mediaDistance;
          const copyOpacity = clamp(1 - progress * (isDesktop ? 1.28 : 0.95), 0, 1);

          const card1Y = -progress * (isDesktop ? 25 : 14);
          const card2Y = -progress * (isDesktop ? 34 : 18);
          const card3Y = -progress * (isDesktop ? 19 : 12);

          hero.style.setProperty("--hero-copy-y", `${copyY.toFixed(2)}px`);
          hero.style.setProperty("--hero-copy-opacity", copyOpacity.toFixed(3));
          hero.style.setProperty("--hero-media-y", `${Math.round(mediaY)}px`);
          hero.style.setProperty("--hero-card-1-y", `${Math.round(card1Y)}px`);
          hero.style.setProperty("--hero-card-2-y", `${Math.round(card2Y)}px`);
          hero.style.setProperty("--hero-card-3-y", `${Math.round(card3Y)}px`);
        });
      };

      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll);
    });
  })();
</script>
