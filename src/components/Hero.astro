---
import Union from "../assets/Union.png";
import Phone from "../assets/phonecaution1.png";
import OverLimit from "../assets/overlimit.png";
import Brands from "../assets/brands.png";
import Lead from "../assets/lead.png";
import { Image } from "astro:assets";
---

<section
  class="section-shell min-h-screen flex items-center pt-24 md:pt-24 pb-14 md:pb-20"
>
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div
      class="absolute -top-24 -left-24 h-[560px] w-[560px] rounded-full bg-purple-900/35 blur-[150px]"
    >
    </div>
    <div
      class="absolute top-0 right-0 h-[560px] w-[560px] rounded-full bg-blue-900/18 blur-[170px]"
    >
    </div>
    <div
      class="absolute left-0 top-1/2 -translate-y-1/2 h-[620px] w-[620px] rounded-full bg-purple-900/20 blur-[190px]"
    >
    </div>
  </div>

  <div
    class="mx-auto grid w-full max-w-full items-center gap-12 md:grid-cols-[minmax(0,1.15fr)_minmax(0,1fr)] md:gap-4"
  >
    <div
      class="order-2 md:order-1 relative ml-0 flex justify-center md:-ml-32 md:justify-start"
    >
      <div class="relative w-full max-w-[800px] min-h-[360px] sm:min-h-[460px] md:min-h-0">
        <Image
          src={Union}
          alt=""
          aria-hidden="true"
          class="absolute left-1/2 top-8 z-0 w-[360px] -translate-x-1/2 object-contain pointer-events-none select-none sm:top-4 sm:w-[480px] md:left-12 md:top-15 md:w-[600px] md:translate-x-0"
        />
        <Image
          src={Phone}
          alt="phone caution"
          class="relative z-10 mx-auto w-[300px] max-w-full sm:w-[380px] md:mx-0 md:ml-52 md:w-auto"
        />

        <Image
          src={OverLimit}
          alt=""
          aria-hidden="true"
          class="pointer-events-none select-none absolute z-20 left-2 top-28 w-[120px] sm:left-6 sm:top-[136px] sm:w-auto md:left-52 md:top-38 overflow-visible"
        />

        <Image
          src={Brands}
          alt=""
          aria-hidden="true"
          class="pointer-events-none select-none absolute z-20 right-0 top-[72px] w-[136px] sm:right-4 sm:top-24 sm:w-auto md:right-9 md:top-32"
        />

        <Image
          src={Lead}
          alt=""
          aria-hidden="true"
          class="pointer-events-none select-none absolute z-20 left-0 bottom-12 w-[152px] sm:left-1 sm:bottom-20 sm:w-auto md:left-38 md:bottom-28"
        />
      </div>
    </div>

    <div class="order-1 md:order-2 md:pl-0 text-center md:text-left">
      <h1
        class="mx-auto max-w-[680px] text-4xl sm:text-5xl md:text-[84px] font-bold leading-[0.98] md:leading-[0.95] tracking-[-0.03em] text-white md:mx-0"
      >
        The only marketplace where every product are lab tested
      </h1>

      <p
        class="mt-6 md:mt-10 text-base sm:text-lg md:text-xl text-white/60 max-w-[600px] font-medium leading-[1.5] md:leading-[1.4] tracking-tight mx-auto md:mx-0"
      >
        We don’t offer you an opinion, we just show you the science. 
        <br>
        If a product passes or fails we show you readable lab results. 
        <br>
        Make healthy decisions, quickly.
      </p>

      <div class="mt-8 md:mt-12 flex justify-center md:justify-start">
        <button
          class="w-[192px] h-[60px] bg-gradient-to-r from-[#2A66FF] to-[#1E48E8] hover:brightness-105 rounded-full font-bold text-base text-white flex items-center justify-center transition-all shadow-[0_15px_40px_rgba(37,99,235,0.45)] border border-white/10 leading-none"
        >
          Search products
        </button>
      </div>
    </div>
  </div>
</section>
