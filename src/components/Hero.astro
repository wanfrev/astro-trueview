---
import Union from "../assets/icons/Union.svg";
import Phone from "../assets/images/phonecaution1.png";
import Brands from "../assets/icons/brands.svg";
import { Image } from "astro:assets";

// Aquí importarás tus SVGs de marcas cuando los tengas listos
// import Logo1 from "../assets/logos/logo1.svg";

// Usamos un único SVG con todas las marcas
const topBrandLogos = Brands;
const heroPhoneSizes = '(max-width: 768px) 78vw, (max-width: 1280px) 46vw, 36vw';
---

<section
  data-hero-root
  data-hero-in-view="false"
  data-bg="hero"
  class="hero-root section-shell relative min-h-screen flex items-center pt-24 sm:pt-28 md:pt-32 lg:pt-36 pb-12 md:pb-20 overflow-hidden"
>
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div
      class="hidden"
    >
    </div>
    <div
      class="hidden"
    >
    </div>
    <div
      class="hidden"
    >
    </div>
  </div>

  <div class="content-shell hero-layout w-full items-center gap-10 lg:gap-8">
    <div data-hero-copy class="hero-copy text-center lg:text-left z-10">
      <h1
        id="hero-title"
        class="hero-reveal hero-reveal-copy-1 mx-auto max-w-[22ch] text-3xl sm:text-4xl lg:text-[46px] xl:text-[56px] 2xl:text-[62px] font-bold leading-[0.98] lg:leading-[0.95] tracking-[-0.03em] text-white lg:mx-0"
      >
        The only marketplace where every product are lab tested
      </h1>

      <p
        class="hero-reveal hero-reveal-copy-2 mt-6 lg:mt-10 text-sm sm:text-base lg:text-[17px] xl:text-[18px] text-white/60 max-w-[56ch] font-medium leading-normal lg:leading-[1.4] tracking-tight mx-auto lg:mx-0"
      >
        We don’t offer you an opinion, we just show you the science.
        <br class="hidden lg:block" />
        If a product passes or fails we show you readable lab results.
        <br class="hidden lg:block" />
        Make healthy decisions, quickly.
      </p>

      <div class="mt-8 lg:mt-12 flex justify-center xl:justify-start">
        <button
          class="hero-reveal hero-reveal-copy-3 w-48 h-15 bg-[#2563eb] hover:brightness-105 rounded-full font-bold text-base text-white flex items-center justify-center transition-all shadow-[0_15px_40px_rgba(37,99,235,0.45)] border border-white/10 leading-none hover:scale-105 active:scale-95"
        >
          Search products
        </button>
      </div>
    </div>

    <div data-hero-media class="hero-media">
      <div class="phone-collage-wrapper">
        <Image
          src={Union}
          alt=""
          aria-hidden="true"
          loading="eager"
          decoding="async"
          class="hero-union-shape"
        />

        <div class="hero-phone-layer hero-reveal hero-reveal-phone">
          <div class="hero-phone-frame">
            <Image
              src={Phone}
              alt="phone caution"
              loading="eager"
              fetchpriority="high"
              format="png"
              widths={[520, 760, 1040, 1320, 1680]}
              sizes={heroPhoneSizes}
              decoding="async"
              class="hero-phone-image"
            />
          </div>
        </div>

        <div data-hero-card="1" class="hero-card-layer hero-reveal hero-reveal-card-1 hero-over-limit-card">
          <div class="hero-over-limit-card-inner">
            <span class="hero-over-limit-value">239.00%</span>
            <span class="hero-over-limit-label">OVER LIMIT</span>
          </div>
        </div>

        <div data-hero-card="2" class="hero-card-layer hero-reveal hero-reveal-card-2 hero-brands-card">
          <div class="hero-brands-card-inner">
            <div class="hero-brands-card-copy">
              <h3 class="hero-brands-title">100+</h3>
              <p class="hero-brands-label">HUNDREDS OF TOP BRANDS</p>
            </div>

            <div class="hero-brands-logo-slot">
              <Image
                src={topBrandLogos}
                alt="Brands"
                loading="lazy"
                decoding="async"
                class="hero-brands-logo"
              />
            </div>
          </div>
        </div>

        <div data-hero-card="3" class="hero-card-layer hero-reveal hero-reveal-card-3 hero-lead-card">
          <div class="hero-lead-card-inner hero-card-float-target">
            <div class="hero-lead-copy">
              <div class="hero-lead-badge">
                <svg class="hero-lead-badge-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </div>
              <div class="hero-lead-text">
                <span class="hero-lead-title">Lead</span>
                <span class="hero-lead-limit">Limit: 0.5 (ppm)</span>
                <div class="hero-lead-detection">
                  <span class="hero-lead-value">1.77</span>
                  <span class="hero-lead-detected">ppm Detected</span>
                </div>
              </div>
            </div>

            <div class="hero-lead-ratio">
              <span class="hero-lead-ratio-value">230.00%</span>
              <span class="hero-lead-ratio-label">over limit</span>
            </div>
          </div>
        </div>

        <div data-hero-card="4" class="hero-card-layer hero-reveal hero-reveal-card-4 hero-caution-card" aria-hidden="true">
          <div class="hero-caution-card-inner">
            <div class="hero-caution-icon-circle">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
              </svg>
            </div>
            <p class="hero-caution-text"><strong>Caution:</strong> Exceeds Proposition 65 Heavy Metals</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-root {
    --hero-copy-y: 0px;
    --hero-copy-opacity: 1;
    --hero-media-y: 0px;
    --hero-mobile-shift: 0px;
    --hero-card-1-y: 0px;
    --hero-card-2-y: 0px;
    --hero-card-3-y: 0px;
    --hero-card-4-y: 0px;
    --hero-card-4-rot: 7deg;
    /* control manual de posición/anchura para la caution card */
    --hero-card-4-left: 19%;
    --hero-card-4-top: 36%;
    --hero-card-4-width: 40%;
    --glass-bg: rgba(255, 255, 255, 0.12);
    --glass-border: rgba(255, 255, 255, 0.2);
    --text-white: #ffffff;
    --hero-card-text: var(--text-white);
    --hero-card-text-muted: rgba(255, 255, 255, 0.72);
    --hero-card-danger: #e85a5a;
    --hero-card-danger-soft: rgba(255, 255, 255, 0.9);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: center;
  }

  .hero-copy {
    transform: translate3d(0, var(--hero-copy-y), 0);
    opacity: var(--hero-copy-opacity);
    will-change: transform, opacity;
    text-align: center;
  }

  .hero-media {
    display: flex;
    justify-content: flex-end;
    min-width: 0;
  }

  @media (min-width: 1025px) {
    .hero-copy {
      order: 2;
      text-align: left;
    }

    .hero-media {
      order: 1;
      justify-content: flex-start;
    }
  }

  .phone-collage-wrapper {
    position: relative;
    width: 100%;
    max-width: 45rem;
    aspect-ratio: 36 / 26;
    margin-inline: auto;
  }

  .hero-union-shape {
    position: absolute;
    left: 2%;
    top: 1.5%;
    width: 75%;
    max-width: 93%;
    height: auto;
    opacity: 0.4;
    pointer-events: none;
    user-select: none;
    object-fit: contain;
  }

  .hero-phone-layer {
    position: absolute;
    left: 3%;
    top: 0;
    width: 74%;
    height: 100%;
    transform: translate3d(var(--hero-mobile-shift), calc(var(--hero-media-y) + var(--hero-reveal-offset, 28px)), 0);
    will-change: transform;
  }

  .hero-phone-frame {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: visible;
    box-sizing: border-box;
  }

  .hero-phone-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: contain;
    object-position: center;
    transition: transform 720ms cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
    transform: scale(1.25);
    will-change: transform;
  }


  .hero-card-layer {
    position: absolute;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .hero-card-float-target,
  .hero-over-limit-card-inner,
  .hero-brands-card-inner,
  .hero-caution-card-inner {
    animation-name: heroCardFloat;
    animation-duration: 4.2s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    will-change: transform;
  }

  .hero-lead-card .hero-card-float-target { animation-delay: -0.5s; animation-duration: 3.8s; }
  .hero-over-limit-card-inner { animation-delay: -0.2s; animation-duration: 3.9s; }
  .hero-brands-card-inner { animation-delay: -0.9s; animation-duration: 4.6s; }
  .hero-caution-card-inner { animation-delay: -1.2s; animation-duration: 4.8s; }

  .hero-card-layer[data-hero-card="1"] {
    left: 13%;
    top: 4.25%;
    width: 19.4%;
    aspect-ratio: 33.5 / 17;
    transform: translate3d(var(--hero-mobile-shift), calc(var(--hero-card-1-y) + var(--hero-reveal-offset, 28px)), 0);
  }

  .hero-card-layer[data-hero-card="2"] {
    right: auto;
    left: 55%;
    top: 12%;
    width: 23.5%;
    aspect-ratio: 39 / 29.5;
    transform: translate3d(var(--hero-mobile-shift), calc(var(--hero-card-2-y) + var(--hero-reveal-offset, 28px)), 0);
  }

  .hero-card-layer[data-hero-card="3"] {
    left: -2%;
    bottom: 12%;
    width: 30%;
    aspect-ratio: 55 / 17.5;
    transform: translate3d(var(--hero-mobile-shift), calc(var(--hero-card-3-y) + var(--hero-reveal-offset, 28px)), 0);
  }

  .hero-card-layer[data-hero-card="4"] {
    left: var(--hero-card-4-left);
    top: var(--hero-card-4-top);
    width: var(--hero-card-4-width);
    aspect-ratio: 46 / 10;
    transform: translate3d(var(--hero-mobile-shift), calc(var(--hero-card-4-y) + var(--hero-reveal-offset, 28px)), 0) rotate(var(--hero-card-4-rot, 0deg));
  }

  .hero-over-limit-card-inner,
  .hero-brands-card-inner,
  .hero-lead-card-inner,
  .hero-caution-card-inner {
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
    color: var(--text-white);
  }

  .hero-over-limit-card-inner {
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
    border-radius: clamp(12px, 1.6vw, 16px);
    padding: 0.5rem;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }


  .hero-over-limit-value {
    color: var(--hero-card-text);
    font-size: clamp(0.78rem, 1.3vw, 1.1rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 2px;
  }

  .hero-over-limit-label {
    color: var(--hero-card-text);
    font-size: clamp(0.32rem, 0.55vw, 0.48rem);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .hero-brands-card-inner {
    height: 100%;
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    gap: 0.2rem;
    border-radius: clamp(14px, 2.2vw, 18px);
    padding: 0.8rem 0.8rem 0.55rem;
    align-items: flex-start;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }


  .hero-brands-card-copy {
    flex: 0 0 auto;
    min-width: 0;
    width: 100%;
  }

  .hero-brands-title {
    color: var(--hero-card-text);
    font-size: clamp(1rem, 1.8vw, 1.55rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.06em;
    margin-bottom: 2px;
  }

  .hero-brands-label {
    margin-bottom: 2px;
    color: var(--hero-card-text);
    font-size: clamp(0.3rem, 0.52vw, 0.44rem);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1.2;
    max-width: 100%;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .hero-brands-logo-slot {
    margin-top: 0;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .hero-brands-logo {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    margin-top: 0;
  }

  .hero-lead-card-inner {
    height: 100%;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    border-radius: clamp(10px, 1.7vw, 14px);
    padding: 6px 6px 6px 12px;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }


  .hero-lead-copy {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    gap: 0.42rem;
    min-width: 0;
    overflow: hidden;
  }

  .hero-lead-badge {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    align-self: flex-start;
    margin-top: 2px;
  }

  .hero-lead-badge-icon {
    width: 14px;
    height: 14px;
    color: var(--hero-card-danger);
  }

  .hero-lead-text {
    flex-grow: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .hero-lead-title {
    color: var(--hero-card-text);
    font-size: clamp(0.55rem, 0.85vw, 0.85rem);
    font-weight: 600;
    line-height: 1.1;
    white-space: nowrap;
  }

  .hero-lead-limit {
    color: var(--hero-card-text-muted);
    font-size: clamp(0.35rem, 0.5vw, 0.6rem);
    line-height: 1.1;
    opacity: 0.7;
    margin-top: 0.12rem;
    white-space: nowrap;
  }

  .hero-lead-detection {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.06rem;
    margin-top: 0.1rem;
    min-width: 0;
    overflow: hidden;
  }

  .hero-lead-value {
    color: #ff6b6b;
    font-size: clamp(0.6rem, 0.85vw, 0.95rem);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .hero-lead-detected {
    color: var(--hero-card-text);
    font-size: clamp(0.35rem, 0.5vw, 0.65rem);
    line-height: 1;
    white-space: nowrap;
  }

  .hero-lead-ratio {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--hero-card-danger);
    border: none;
    border-radius: 10px;
    height: 100%;
    min-height: 40px;
    width: 36%;
    box-shadow: none;
    min-width: 0;
    overflow: hidden;
  }

  .hero-lead-ratio-value {
    color: var(--hero-card-text);
    font-size: clamp(0.6rem, 0.85vw, 0.9rem);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .hero-lead-ratio-label {
    margin-top: 2px;
    color: var(--hero-card-text);
    font-size: clamp(0.3rem, 0.5vw, 0.45rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
    opacity: 0.9;
    white-space: nowrap;
  }

  .hero-caution-card-inner {
    height: 100%;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    border-radius: clamp(10px, 1.4vw, 14px);
    padding: 10px 14px;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    min-width: 0; /* permite que los hijos flexibles se encojan sin overflow */
  }


  .hero-caution-icon-circle {
    background: #ff5b58;
    color: #ffffff;
    width: 20px;
    height: 20px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero-caution-icon-circle svg {
    width: 12px;
    height: 12px;
  }

  .hero-caution-text {
    color: #ff5b58;
    margin: 0;
    font-size: clamp(0.5rem, 0.7vw, 0.65rem);
    font-weight: 500;
    line-height: 1.2;
    white-space: normal; /* permitir salto de línea */
    overflow-wrap: anywhere; /* romper palabras largas si es necesario */
    flex: 1 1 auto; /* ocupar el espacio restante y permitir encoger */
    min-width: 0; /* esencial para el comportamiento de flexbox */
  }

  .hero-reveal {
    --hero-reveal-offset: 28px;
    opacity: 0;
    transform: translate3d(0, var(--hero-reveal-offset), 0);
    transition-property: opacity, transform;
    transition-duration: 760ms;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-reveal-copy-1 { transition-delay: 60ms; }
  .hero-reveal-copy-2 { transition-delay: 140ms; }
  .hero-reveal-copy-3 { transition-delay: 220ms; }
  .hero-reveal-phone { transition-delay: 120ms; }
  .hero-reveal-card-1 { transition-delay: 200ms; }
  .hero-reveal-card-2 { transition-delay: 260ms; }
  .hero-reveal-card-3 { transition-delay: 320ms; }
  .hero-reveal-card-4 { transition-delay: 360ms; }

  .hero-root[data-hero-in-view="true"] .hero-reveal {
    opacity: 1;
    --hero-reveal-offset: 0px;
  }

  @keyframes heroCardFloat {
    0% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -11px, 0); }
    100% { transform: translate3d(0, 0, 0); }
  }

  @media (max-width: 1024px) {
    .hero-root {
      --hero-mobile-shift: 16px;
    }

    .hero-layout {
      grid-template-columns: 1fr;
      justify-items: center;
    }

    .hero-copy {
      text-align: center;
      justify-self: center;
    }

    .hero-media {
      width: 100%;
      justify-content: center;
    }

    .phone-collage-wrapper {
      max-width: 500px;
    }

    .hero-union-shape {
      left: 50%;
      top: 3%;
      width: 82%;
      transform: translateX(-50%);
    }

    .hero-phone-layer {
      left: 20%;
      width: 52%;
    }

    .hero-card-layer[data-hero-card="1"] {
      left: 8%;
      top: 3.5%;
      width: 21%;
    }

    .hero-card-layer[data-hero-card="2"] {
      right: auto;
      left: 48%;
      top: 12%;
      width: 25%;
    }

    .hero-card-layer[data-hero-card="3"] {
      left: 2%;
      bottom: 13%;
      width: 32%;
    }

    .hero-card-layer[data-hero-card="4"] {
      left: 21%;
      top: 36%;
      width: 34%;
    }

    .hero-lead-card-inner {
      gap: 0.32rem;
      padding: 0.24rem 0.22rem 0.24rem 0.26rem;
      border-radius: 16px;
    }

    .hero-lead-copy {
      gap: 0.3rem;
    }

    .hero-lead-badge {
      width: 1.7rem;
    }

    .hero-lead-ratio {
      width: 40%;
      padding: 0.18rem 0.25rem;
    }

    .hero-brands-logo {
      max-width: 100%;
    }
  }

  @media (min-width: 641px) and (max-width: 1024px) {
    .hero-card-layer[data-hero-card="1"] {
      left: 12%;
    }

    .hero-card-layer[data-hero-card="2"] {
      top: 12%;
      left: 50%;
      right: auto;
    }

    .hero-card-layer[data-hero-card="4"] {
      left: 21%;
      top: 36%;
      width: 34%;
    }
  }

  @media (max-width: 640px) {
    .hero-root {
      --hero-mobile-shift: 12px;
    }

    .phone-collage-wrapper {
      max-width: 400px;
    }

    .hero-phone-frame {
      padding-right: 0.35rem;
    }

    .hero-phone-layer {
      left: 15%;
      width: 55%;
    }

    .hero-card-layer[data-hero-card="1"] {
      left: 12%;
      top: 6%;
      width: 25%;
    }

    .hero-card-layer[data-hero-card="2"] {
      right: auto;
      left: 60%;
      top: 10%;
      width: 27%;
    }

    .hero-card-layer[data-hero-card="3"] {
      left: 0%;
      bottom: 10%;
      width: 46%;
    }

    .hero-card-layer[data-hero-card="4"] {
      left: 27.5%;
      top: 37%;
      width: 30%;
    }

    .hero-over-limit-card-inner {
      gap: 0.22rem;
      padding: 0.58rem 0.65rem;
      border-radius: 10px;
    }

    .hero-over-limit-value {
      font-size: clamp(0.88rem, 3.4vw, 1.08rem);
    }

    .hero-over-limit-label {
      font-size: clamp(0.42rem, 1.45vw, 0.58rem);
      letter-spacing: 0.12em;
    }

    .hero-brands-card-inner {
      padding: 0.62rem 0.6rem 0.48rem;
      border-radius: 18px;
