---
// Importa solo el teléfono y los recursos de fondo.
// ¡Ya puedes borrar los imports de overlimit, brands y lead en PNG!
import Union from "../assets/icons/Union.svg";
import Phone from "../assets/images/phonecaution1.png";
import Brands from "../assets/icons/brands.svg";
import { Image } from "astro:assets";

// Aquí importarás tus SVGs de marcas cuando los tengas listos
// import Logo1 from "../assets/logos/logo1.svg";

// Usamos un único SVG con todas las marcas
const topBrandLogos = Brands;
---

<section
  data-bg="hero"
  class="section-shell relative min-h-screen flex items-center pt-32 md:pt-36 pb-14 md:pb-20 overflow-hidden"
>
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div
      class="hidden"
    >
    </div>
    <div
      class="hidden"
    >
    </div>
    <div
      class="hidden"
    >
    </div>
  </div>

  <div class="content-shell grid w-full items-center gap-12 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-8">
    <div
      class="order-2 lg:order-1 relative flex justify-center lg:justify-start"
    >
      <div
        class="relative w-full max-w-[720px] min-h-[360px] sm:min-h-[460px] lg:min-h-[520px] perspective-[1000px] origin-center lg:origin-left lg:scale-[0.9] xl:scale-100 2xl:scale-[1.08] transition-transform duration-300"
      >
        <Image
          src={Union}
          alt=""
          aria-hidden="true"
          class="absolute left-1/2 top-8 z-0 w-[360px] -translate-x-1/2 object-contain pointer-events-none select-none sm:top-4 sm:w-[480px] lg:left-[8%] lg:top-[200px] lg:w-[75%] lg:max-w-[600px] lg:translate-x-0 opacity-40"
        />

        <!-- Ellipse2 moved to section background to avoid clipping by the phone container -->

        <Image
          src={Phone}
          alt="phone caution"
          class="relative z-10 mx-auto w-[300px] max-w-full sm:w-[380px] lg:mx-0 lg:ml-[18%] lg:w-[430px] xl:w-[470px] 2xl:w-[510px] drop-shadow-2xl"
        />

        <div
          class="absolute z-20 left-[2%] top-[112px] sm:left-[6%] sm:top-[136px] lg:left-[21%] lg:top-[146px] xl:left-[24%] xl:top-[138px] transition-transform duration-500 hover:-translate-y-2 hover:scale-105"
        >
          <div
            class="flex h-[73px] w-[143px] flex-col items-center justify-center rounded-[7px] border border-white/20 bg-[#5b5570] px-3 shadow-[0_12px_28px_rgba(0,0,0,0.36)] backdrop-blur-xl"
          >
            <span class="text-white text-[20px] font-bold tracking-tight leading-none">239.00%</span>
            <span class="text-white/90 text-[10px] tracking-[0.2em] uppercase mt-1">Over Limit</span>
          </div>
        </div>

        <div
          class="absolute z-20 right-[2%] top-[72px] sm:right-[4%] sm:top-24 lg:right-[8%] lg:top-[92px] xl:right-[5%] transition-all duration-500 hover:-translate-y-2"
        >
          <div
            class="relative w-[168px] h-[127px] rounded-[32px] border border-white/10 bg-[#4d465f]/90 p-4 shadow-[0_30px_60px_rgba(0,0,0,0.4)] backdrop-blur-2xl sm:w-[168px] sm:h-[127px]"
          >
            <div class="relative z-10 flex flex-col h-full">
              <div class="flex-0">
                <h3
                  class="text-white text-[28px] font-bold leading-none tracking-tighter"
                >
                  100+
                </h3>
                <p
                  class="mt-1 text-white/60 text-[8px] font-bold uppercase tracking-[0.1em]"
                >
                  Hundreds of top brands
                </p>
              </div>

              <div class="mt-auto flex items-center justify-center">
                <Image
                  src={topBrandLogos}
                  alt="Brands"
                  class="h-8 w-auto object-contain"
                />
              </div>
            </div>
          </div>
        </div>

        <div
          class="absolute z-30 left-[1%] bottom-[48px] sm:left-[2%] sm:bottom-[82px] lg:left-[18%] lg:bottom-[104px] xl:left-[22%] transition-all duration-500 hover:-translate-y-2"
        >
          <div
            class="relative w-[240px] h-[75px] rounded-[18px] bg-[#6f6676] shadow-[0_20px_40px_rgba(0,0,0,0.6)] flex items-center p-2 gap-2 border border-white/20 backdrop-blur-md"
          >
            <div class="flex items-center gap-2 flex-1 pl-1">
              <div class="h-8 w-8 rounded-full bg-[#FFEAE8] flex items-center justify-center shrink-0 shadow-inner">
                <svg class="h-3 w-3 text-[#FF5B5B]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </div>
              <div class="flex flex-col">
                <span class="text-white font-semibold text-sm leading-tight">Lead</span>
                <span class="text-white/60 text-[9px] mb-0.5">Limit: 0.5 (ppm)</span>
                <div class="flex items-baseline gap-1 mt-0.5">
                  <span class="text-[#FF5B5B] font-bold text-sm leading-none">1.77</span>
                  <span class="text-white/70 text-[9px]">ppm Detected</span>
                </div>
              </div>
            </div>

            <div class="flex h-12 w-[86px] shrink-0 items-center justify-center rounded-xl bg-[#ef4444] px-2 shadow-[0_5px_15px_rgba(238,95,95,0.4)] border border-red-400/50">
              <div class="flex flex-col items-center">
                <span class="text-white font-bold text-sm leading-none">230.00%</span>
                <span class="text-white/90 text-[9px] mt-1 tracking-wide">over limit</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="order-1 lg:order-2 text-center lg:text-left z-10">
      <h1
        id="hero-title"
        class="mx-auto max-w-[22ch] text-4xl sm:text-5xl lg:text-[52px] xl:text-[64px] 2xl:text-[72px] font-bold leading-[0.98] lg:leading-[0.95] tracking-[-0.03em] text-white lg:mx-0"
      >
        The only marketplace where every product is lab tested
      </h1>

      <p
        class="mt-6 lg:mt-10 text-base sm:text-lg lg:text-[19px] xl:text-xl text-white/60 max-w-[56ch] font-medium leading-[1.5] lg:leading-[1.4] tracking-tight mx-auto lg:mx-0"
      >
        We don’t offer you an opinion, we just show you the science.
        <br class="hidden lg:block" />
        If a product passes or fails we show you readable lab results.
        <br class="hidden lg:block" />
        Make healthy decisions, quickly.
      </p>

      <div class="mt-8 lg:mt-12 flex justify-center lg:justify-start">
        <button
          class="w-[192px] h-[60px] bg-[#2563eb] hover:brightness-105 rounded-full font-bold text-base text-white flex items-center justify-center transition-all shadow-[0_15px_40px_rgba(37,99,235,0.45)] border border-white/10 leading-none hover:scale-105 active:scale-95"
        >
          Search products
        </button>
      </div>
    </div>
  </div>
</section>
