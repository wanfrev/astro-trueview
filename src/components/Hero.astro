---
// Importa solo el teléfono y los recursos de fondo.
// ¡Ya puedes borrar los imports de overlimit, brands y lead en PNG!
import Union from "../assets/icons/Union.svg";
import Phone from "../assets/images/phonecaution1.png";
import Brands from "../assets/icons/brands.svg";
import { Image } from "astro:assets";

// Aquí importarás tus SVGs de marcas cuando los tengas listos
// import Logo1 from "../assets/logos/logo1.svg";

// Usamos un único SVG con todas las marcas
const topBrandLogos = Brands;
---

<section
  data-hero-root
  data-hero-in-view="false"
  data-bg="hero"
  class="hero-root section-shell relative min-h-screen flex items-center pt-32 md:pt-36 pb-14 md:pb-20 overflow-hidden"
>
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div
      class="hidden"
    >
    </div>
    <div
      class="hidden"
    >
    </div>
    <div
      class="hidden"
    >
    </div>
  </div>

  <div class="content-shell grid w-full items-center gap-12 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-8">
    <div
      data-hero-media
      class="hero-media order-2 lg:order-1 relative flex justify-center lg:justify-start"
    >
      <div
        class="relative w-full max-w-[720px] min-h-[360px] sm:min-h-[460px] lg:min-h-[520px] perspective-[1000px] origin-center lg:origin-left lg:scale-[0.84] xl:scale-[0.96] 2xl:scale-[1.02] transition-transform duration-300"
      >
        <Image
          src={Union}
          alt=""
          aria-hidden="true"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="absolute left-1/2 top-8 z-0 w-[360px] -translate-x-1/2 object-contain pointer-events-none select-none sm:top-4 sm:w-[480px] lg:left-[2%] lg:top-[200px] lg:w-[75%] lg:max-w-[600px] lg:translate-x-0 opacity-40"
        />

        <!-- Ellipse2 moved to section background to avoid clipping by the phone container -->

        <div class="hero-phone-layer hero-reveal hero-reveal-phone relative z-10">
          <div class="hero-phone-frame mx-auto h-[357px] w-[250px] max-w-full sm:h-[451px] sm:w-[316px] lg:mx-0 lg:ml-[10%] lg:h-[472px] lg:w-[331px] xl:h-[516px] xl:w-[353px] 2xl:h-[562px] 2xl:w-[384px]">
            <img
              src={Phone.src}
              width={Phone.width}
              height={Phone.height}
              alt="phone caution"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="hero-phone-image"
            />
          </div>
        </div>

        <div
          data-hero-card="1"
          class="hero-card-layer hero-reveal hero-reveal-card-1 absolute z-20 left-[-8%] top-[72px] sm:left-[-1%] sm:top-[92px] lg:left-[10%] lg:top-[96px] xl:left-[13%] xl:top-[88px]"
        >
          <div
            class="transition-transform duration-500 hover:-translate-y-2 hover:scale-105 flex h-[60px] w-[116px] flex-col items-center justify-center rounded-[7px] border border-white/20 bg-[#5b5570] px-2.5 shadow-[0_12px_28px_rgba(0,0,0,0.36)] backdrop-blur-xl sm:h-[68px] sm:w-[134px] sm:px-3"
          >
            <span class="text-white text-[17px] font-bold tracking-tight leading-none sm:text-[20px]">239.00%</span>
            <span class="text-white/90 text-[8px] tracking-[0.16em] uppercase mt-1 sm:text-[10px] sm:tracking-[0.2em]">Over Limit</span>
          </div>
        </div>

        <div
          data-hero-card="2"
          class="hero-card-layer hero-reveal hero-reveal-card-2 absolute z-20 right-[17%] top-[68px] sm:right-[18%] sm:top-[72px] lg:right-[23%] lg:top-[74px] xl:right-[20%] xl:top-[70px]"
        >
          <div
            class="transition-all duration-500 hover:-translate-y-2 relative w-[130px] h-[100px] rounded-[26px] border border-white/10 bg-[#4d465f]/90 p-3 shadow-[0_30px_60px_rgba(0,0,0,0.4)] backdrop-blur-2xl sm:w-[156px] sm:h-[118px] sm:rounded-4xl sm:p-4"
          >
            <div class="relative z-10 flex flex-col h-full">
              <div class="flex-0">
                <h3
                  class="text-white text-[23px] font-bold leading-none tracking-tighter sm:text-[28px]"
                >
                  100+
                </h3>
                <p
                  class="mt-1 text-white/60 text-[7px] font-bold uppercase tracking-[0.08em] sm:text-[8px] sm:tracking-widest"
                >
                  Hundreds of top brands
                </p>
              </div>

              <div class="mt-auto flex items-center justify-center">
                <Image
                  src={topBrandLogos}
                  alt="Brands"
                  loading="eager"
                  decoding="async"
                  class="h-6 w-auto object-contain sm:h-8"
                />
              </div>
            </div>
          </div>
        </div>

        <div
          data-hero-card="3"
          class="hero-card-layer hero-reveal hero-reveal-card-3 absolute z-30 left-[-6%] bottom-[42px] sm:left-[-2%] sm:bottom-[82px] lg:left-[1%] lg:bottom-[96px] xl:left-[5%]"
        >
          <div
            class="transition-all duration-500 hover:-translate-y-2 relative w-[190px] h-[62px] rounded-2xl bg-[#6f6676] shadow-[0_20px_40px_rgba(0,0,0,0.6)] flex items-center p-1.5 gap-1.5 border border-white/20 backdrop-blur-md sm:w-[220px] sm:h-[70px] sm:rounded-[18px] sm:p-2 sm:gap-2"
          >
            <div class="flex items-center gap-1.5 flex-1 pl-0.5 sm:gap-2 sm:pl-1">
              <div class="h-7 w-7 rounded-full bg-[#FFEAE8] flex items-center justify-center shrink-0 shadow-inner sm:h-8 sm:w-8">
                <svg class="h-2.5 w-2.5 text-[#FF5B5B] sm:h-3 sm:w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </div>
              <div class="flex flex-col">
                <span class="text-white font-semibold text-[12px] leading-tight sm:text-sm">Lead</span>
                <span class="text-white/60 text-[8px] mb-0.5 sm:text-[9px]">Limit: 0.5 (ppm)</span>
                <div class="flex items-baseline gap-1 mt-0.5">
                  <span class="text-[#FF5B5B] font-bold text-[12px] leading-none sm:text-sm">1.77</span>
                  <span class="text-white/70 text-[8px] sm:text-[9px]">ppm Detected</span>
                </div>
              </div>
            </div>

            <div class="flex h-10 w-[68px] shrink-0 items-center justify-center rounded-[10px] bg-[#ef4444] px-1.5 shadow-[0_5px_15px_rgba(238,95,95,0.4)] border border-red-400/50 sm:h-12 sm:w-[78px] sm:rounded-xl sm:px-2">
              <div class="flex flex-col items-center">
                <span class="text-white font-bold text-[12px] leading-none sm:text-sm">230.00%</span>
                <span class="text-white/90 text-[8px] mt-0.5 tracking-wide sm:text-[9px] sm:mt-1">over limit</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div data-hero-copy class="hero-copy order-1 lg:order-2 text-center lg:text-left z-10">
      <h1
        id="hero-title"
        class="hero-reveal hero-reveal-copy-1 mx-auto max-w-[22ch] text-4xl sm:text-5xl lg:text-[52px] xl:text-[64px] 2xl:text-[70px] font-bold leading-[0.98] lg:leading-[0.95] tracking-[-0.03em] text-white lg:mx-0"
      >
        The only marketplace where every product is lab tested
      </h1>

      <p
        class="hero-reveal hero-reveal-copy-2 mt-6 lg:mt-10 text-base sm:text-lg lg:text-[19px] xl:text-xl text-white/60 max-w-[56ch] font-medium leading-normal lg:leading-[1.4] tracking-tight mx-auto lg:mx-0"
      >
        We don’t offer you an opinion, we just show you the science.
        <br class="hidden lg:block" />
        If a product passes or fails we show you readable lab results.
        <br class="hidden lg:block" />
        Make healthy decisions, quickly.
      </p>

      <div class="mt-8 lg:mt-12 flex justify-center lg:justify-start">
        <button
          class="hero-reveal hero-reveal-copy-3 w-48 h-15 bg-[#2563eb] hover:brightness-105 rounded-full font-bold text-base text-white flex items-center justify-center transition-all shadow-[0_15px_40px_rgba(37,99,235,0.45)] border border-white/10 leading-none hover:scale-105 active:scale-95"
        >
          Search products
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-root {
    --hero-copy-y: 0px;
    --hero-copy-opacity: 1;
    --hero-media-y: 0px;
    --hero-card-1-y: 0px;
    --hero-card-2-y: 0px;
    --hero-card-3-y: 0px;
  }

  .hero-copy {
    transform: translate3d(0, var(--hero-copy-y), 0);
    opacity: var(--hero-copy-opacity);
    will-change: transform, opacity;
  }

  .hero-media {
    will-change: auto;
  }

  .hero-phone-layer {
    transform: translate3d(0, var(--hero-media-y), 0);
    will-change: transform;
  }

  .hero-phone-frame {
    position: relative;
    overflow: hidden;
  }

  .hero-phone-image {
    position: absolute;
    left: -16.01%;
    top: -13.81%;
    width: 143.69%;
    height: 127.66%;
    max-width: none;
    object-fit: contain;
  }

  .hero-card-layer[data-hero-card="1"] {
    transform: translate3d(0, var(--hero-card-1-y), 0);
    will-change: transform;
  }

  .hero-card-layer[data-hero-card="2"] {
    transform: translate3d(0, var(--hero-card-2-y), 0);
    will-change: transform;
  }

  .hero-card-layer[data-hero-card="3"] {
    transform: translate3d(0, var(--hero-card-3-y), 0);
    will-change: transform;
  }

  .hero-reveal {
    opacity: 0;
    transform: translate3d(0, 28px, 0);
    transition-property: opacity, transform;
    transition-duration: 760ms;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-reveal-copy-1 { transition-delay: 60ms; }
  .hero-reveal-copy-2 { transition-delay: 140ms; }
  .hero-reveal-copy-3 { transition-delay: 220ms; }
  .hero-reveal-phone { transition-delay: 120ms; }
  .hero-reveal-card-1 { transition-delay: 200ms; }
  .hero-reveal-card-2 { transition-delay: 260ms; }
  .hero-reveal-card-3 { transition-delay: 320ms; }

  .hero-root[data-hero-in-view="true"] .hero-reveal {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-copy,
    .hero-phone-layer,
    .hero-card-layer[data-hero-card="1"],
    .hero-card-layer[data-hero-card="2"],
    .hero-card-layer[data-hero-card="3"] {
      transform: none !important;
    }

    .hero-reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const heroes = document.querySelectorAll("[data-hero-root]");

    heroes.forEach((hero) => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      hero.setAttribute("data-hero-in-view", "false");

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              hero.setAttribute("data-hero-in-view", "true");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.28 }
      );

      revealObserver.observe(hero);

      if (prefersReducedMotion) {
        hero.style.setProperty("--hero-copy-y", "0px");
        hero.style.setProperty("--hero-copy-opacity", "1");
        hero.style.setProperty("--hero-media-y", "0px");
        hero.style.setProperty("--hero-card-1-y", "0px");
        hero.style.setProperty("--hero-card-2-y", "0px");
        hero.style.setProperty("--hero-card-3-y", "0px");
        return;
      }

      let rafId = 0;
      const onScroll = () => {
        if (rafId !== 0) {
          return;
        }

        rafId = window.requestAnimationFrame(() => {
          rafId = 0;

          const rect = hero.getBoundingClientRect();
          const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
          const isDesktop = window.matchMedia("(min-width: 1024px)").matches;

          // Start parallax only after the hero begins leaving the top of the viewport.
          const scrolledPastTop = Math.max(0, -rect.top);
          const travelDistance = rect.height * (isDesktop ? 0.72 : 0.55);
          const progress = clamp(scrolledPastTop / Math.max(travelDistance, 1), 0, 1);

          const copyDistance = isDesktop ? 124 : 70;
          const mediaDistance = isDesktop ? 46 : 26;
          const copyY = -progress * copyDistance;
          const mediaY = -progress * mediaDistance;
          const copyOpacity = clamp(1 - progress * (isDesktop ? 1.28 : 0.95), 0, 1);

          const card1Y = -progress * (isDesktop ? 25 : 14);
          const card2Y = -progress * (isDesktop ? 34 : 18);
          const card3Y = -progress * (isDesktop ? 19 : 12);

          hero.style.setProperty("--hero-copy-y", `${copyY.toFixed(2)}px`);
          hero.style.setProperty("--hero-copy-opacity", copyOpacity.toFixed(3));
          hero.style.setProperty("--hero-media-y", `${Math.round(mediaY)}px`);
          hero.style.setProperty("--hero-card-1-y", `${Math.round(card1Y)}px`);
          hero.style.setProperty("--hero-card-2-y", `${Math.round(card2Y)}px`);
          hero.style.setProperty("--hero-card-3-y", `${Math.round(card3Y)}px`);
        });
      };

      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll);
    });
  })();
</script>
