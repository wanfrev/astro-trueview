---
import Mockups7 from '../assets/images/Mockups7.png';
---

<section data-bg="good-bad-2" class="section-shell py-16 lg:py-24 relative overflow-hidden" style="--goodandbad-label-size:1.375rem; --goodandbad-h2-size:3.75rem; --goodandbad-body-size:1.25rem;">
	<div class="content-shell relative">
		<!-- Contenedor grid superpuesto -->
		<div class="grid grid-cols-1 items-center">
			<!-- Imagen de fondo full-bleed -->
			<div class="col-start-1 row-start-1 w-full flex justify-end overflow-visible">
				<img
					src={Mockups7.src ?? Mockups7}
					alt="Good and the Bad mockup"
					class="block h-auto w-[165%] sm:w-[145%] lg:w-[105%] xl:w-[92%] max-w-none -translate-x-[10%] lg:-translate-x-[6%]"
					style="max-width: none;"
					loading="eager"
					decoding="async"
				/>
			</div>

			<!-- Texto superpuesto encima de la imagen -->
			<div class="col-start-1 row-start-1 z-10 flex flex-col gap-5 lg:gap-6 items-start text-left w-full max-w-[620px] px-6 lg:px-12 self-start translate-x-[4%] sm:translate-x-[8%] lg:translate-x-[10%] -translate-y-[16%] lg:-translate-y-[20%]">
				<span class="text-[#ff5b58] font-bold" style="font-size: var(--goodandbad-label-size, 1.125rem);">The Good and the Bad</span>

				<h2 style="font-size: var(--goodandbad-h2-size, 3.625rem);" class="text-3xl sm:text-4xl lg:text-[48px] xl:text-[58px] font-bold leading-[1.08] lg:leading-[1.06] tracking-[-0.03em]">
					Reading lab reports sucks. <br />
					<span class="text-white">We show you the critical information</span>
				</h2>

				<p style="font-size: var(--goodandbad-body-size, 1.125rem);" class="text-gray-400 text-base sm:text-lg lg:text-xl leading-relaxed max-w-[52ch]">
					We don’t offer you an opinion, we just show you the science.
					If a product passes or fails we show you readable lab results.
					Make healthy decisions, quickly.
				</p>
			</div>

		</div>
	</div>
</section>
