---
import Mockups7 from '../assets/images/Mockups7.png';
---

<section data-bg="good-bad-2" class="section-shell py-16 md:py-24 relative overflow-hidden px-0!" style="--goodandbad-label-size:1.375rem; --goodandbad-h2-size:3.75rem; --goodandbad-body-size:1.25rem;">
	<div class="relative mx-auto w-screen max-w-none left-1/2 -translate-x-1/2">
		<!-- Contenedor grid superpuesto -->
		<div class="grid grid-cols-1 items-center">
			<!-- Imagen de fondo full-bleed -->
			<div class="col-start-1 row-start-1 w-screen flex justify-end overflow-visible">
				<img
					src={Mockups7.src ?? Mockups7}
					alt="Good and the Bad mockup"
					class="block h-auto w-[180%] md:w-[110%] lg:w-[90%] max-w-none -translate-x-[6%] md:-translate-x-[6%]"
					style="max-width: none;"
					loading="eager"
					decoding="async"
				/>
			</div>

			<!-- Texto superpuesto encima de la imagen -->
			<div class="col-start-1 row-start-1 z-10 flex flex-col gap-5 md:gap-6 items-start text-left w-full max-w-190 px-6 md:px-12 lg:px-24 self-start translate-x-[10%] md:translate-x-[18%] -translate-y-[18%] md:-translate-y-[22%]">
				<span class="text-[#ff5b58] font-bold" style="font-size: var(--goodandbad-label-size, 1.125rem);">The Good and the Bad</span>

				<h2 style="font-size: var(--goodandbad-h2-size, 3.625rem);" class="text-3xl sm:text-4xl md:text-[58px] font-bold leading-[1.08] md:leading-[1.06] tracking-[-0.03em]">
					Reading lab reports sucks. <br />
					<span class="text-white">We show you the critical information</span>
				</h2>

				<p style="font-size: var(--goodandbad-body-size, 1.125rem);" class="text-gray-400 text-base sm:text-lg leading-relaxed max-w-md md:max-w-130">
					We don’t offer you an opinion, we just show you the science.
					If a product passes or fails we show you readable lab results.
					Make healthy decisions, quickly.
				</p>
			</div>

		</div>
	</div>
</section>
