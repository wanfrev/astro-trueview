---
import Collage1 from '../assets/images/collage1.png';
import Collage2 from '../assets/images/collage2.png';
import Collage3 from '../assets/images/collage3.png';
import Collage4 from '../assets/images/collage4.png';
import Collage5 from '../assets/images/collage5.png';
import { Image } from 'astro:assets';

const goodbadSizes = '(max-width: 480px) 84vw, (max-width: 640px) 72vw, (max-width: 1279px) 42vw, 21vw';
const goodbadWideSizes = '(max-width: 480px) 100vw, (max-width: 640px) 100vw, (max-width: 1279px) 84vw, 23vw';
---

<section data-bg="good-bad-2" class="section-shell relative overflow-hidden py-14 sm:py-16 lg:py-24">
	<div class="content-shell relative">
		<div class="goodbad-layout">
			<div data-reveal-group class="goodbad-copy">
				<span class="motion-reveal motion-reveal-impact motion-word-glow motion-word-glow-red text-lg font-black tracking-[-0.02em] text-[#ff5b58] sm:text-xl lg:text-2xl">The Good and the Bad</span>

				<h2 class="motion-reveal motion-reveal-impact motion-reveal-left max-w-[19ch] text-[34px] font-bold leading-[1.06] tracking-[-0.03em] sm:text-3xl lg:text-[32px] lg:leading-[1.04] xl:text-[36px]">
					Reading lab reports sucks. <br />
					<span class="text-white">We show you the critical information</span>
				</h2>

				<p style="--reveal-delay: 120ms;" class="motion-reveal motion-reveal-impact motion-reveal-left max-w-[56ch] text-[15px] leading-relaxed text-gray-400 sm:text-sm lg:text-[16px] xl:text-[18px]">
					We don’t offer you an opinion, we just show you the science.
					If a product passes or fails we show you readable lab results.
					Make healthy decisions, quickly.
				</p>
			</div>

			<div class="goodbad-visual-layer" aria-hidden="true">
				<div class="goodbad-visual-stage">
					<div aria-hidden="true" class="goodbad-glow goodbad-glow--red"></div>
					<div aria-hidden="true" class="goodbad-glow goodbad-glow--white"></div>

					<div class="goodbad-item goodbad-item--1 motion-reveal motion-reveal-left motion-hover-lift">
						<div class="motion-float-soft goodbad-float goodbad-float--1">
							<Image src={Collage1} alt="Zinc Test" widths={[280, 360, 460, 560, 720]} sizes={goodbadSizes} format="webp" quality={74} loading="eager" fetchpriority="high" decoding="async" class="goodbad-image goodbad-image--1" />
						</div>
					</div>

					<div class="goodbad-item goodbad-item--2 motion-reveal motion-reveal-zoom motion-hover-lift">
						<div class="motion-float-soft goodbad-float goodbad-float--2">
							<Image src={Collage2} alt="Protein list" widths={[280, 360, 460, 560, 720]} sizes={goodbadSizes} format="webp" quality={74} loading="eager" fetchpriority="high" decoding="async" class="goodbad-image goodbad-image--2" />
						</div>
					</div>

					<div class="goodbad-item goodbad-item--3 motion-reveal motion-reveal-right motion-hover-lift">
						<div class="motion-float-soft goodbad-float goodbad-float--3">
							<Image src={Collage3} alt="Mold failure" widths={[280, 360, 460, 560, 720]} sizes={goodbadSizes} format="webp" quality={74} loading="eager" fetchpriority="high" decoding="async" class="goodbad-image goodbad-image--3" />
						</div>
					</div>

					<div class="goodbad-item goodbad-item--4 motion-reveal motion-reveal-left motion-hover-lift">
						<div class="motion-float-soft goodbad-float goodbad-float--4">
							<Image src={Collage5} alt="ACV Gummies" widths={[300, 420, 560, 720, 880]} sizes={goodbadSizes} format="webp" quality={74} loading="eager" decoding="async" class="goodbad-image goodbad-image--4" />
						</div>
					</div>

					<div class="goodbad-item goodbad-item--5 motion-reveal motion-reveal-zoom motion-hover-lift">
						<div class="motion-float-soft goodbad-float goodbad-float--5">
							<Image src={Collage4} alt="Lead levels" widths={[360, 480, 640, 840, 1024]} sizes={goodbadWideSizes} format="webp" quality={74} loading="eager" decoding="async" class="goodbad-image goodbad-image--5" />
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
	(() => {
		document.documentElement.classList.add('goodbad-image-anim-ready');

		const imageSelector = '.goodbad-image';

		const markLoaded = (image) => {
			image.classList.add('is-loaded');
		};

		const setupImageReveal = () => {
			document.querySelectorAll(imageSelector).forEach((image) => {
				if (image.dataset.loadBound === 'true') {
					return;
				}

				image.dataset.loadBound = 'true';

				if (image.complete && image.naturalWidth > 0) {
					markLoaded(image);
					return;
				}

				image.addEventListener('load', () => markLoaded(image), { once: true });
				image.addEventListener('error', () => markLoaded(image), { once: true });
			});
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', setupImageReveal, { once: true });
		} else {
			setupImageReveal();
		}

		document.addEventListener('astro:page-load', setupImageReveal);
	})();
</script>

<style>
	.goodbad-layout {
		position: relative;
		width: 100%;
		min-height: clamp(31.25rem, 55vw, 53.75rem);
		isolation: isolate;
	}

	.goodbad-copy {
		position: relative;
		z-index: 30;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: clamp(0.75rem, 1vw, 1rem);
		width: min(100%, 55rem);
		padding-inline: clamp(0.25rem, 1.5vw, 2.5rem);
		padding-top: clamp(0.5rem, 1.5vw, 2.25rem);
		text-align: left;
	}

	.goodbad-visual-layer {
		position: absolute;
		inset: 0;
		z-index: 10;
		display: flex;
		justify-content: center;
		transform: translateY(5%);
	}

	.goodbad-visual-stage {
		position: relative;
		width: 100%;
		max-width: 1536px;
		aspect-ratio: 1536 / 860;
		overflow: visible;
	}

	.goodbad-glow {
		position: absolute;
		pointer-events: none;
		z-index: 0;
		border-radius: 9999px;
		filter: blur(64px);
	}

	.goodbad-glow--red {
		left: 8%;
		top: 18%;
		height: 58%;
		width: 52%;
		background: radial-gradient(circle at center, rgba(255, 91, 88, 0.28) 0%, rgba(255, 91, 88, 0.14) 28%, rgba(255, 91, 88, 0.05) 48%, transparent 74%);
	}

	.goodbad-glow--white {
		right: 4%;
		top: 2%;
		height: 46%;
		width: 40%;
		background: radial-gradient(circle at center, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0.08) 30%, rgba(255, 255, 255, 0.03) 52%, transparent 76%);
	}

	.goodbad-item {
		position: absolute;
		z-index: 10;
		will-change: transform;
	}

	.goodbad-item--1 {
		left: 6%;
		top: 39%;
		width: 20%;
		z-index: 20;
		--reveal-delay: 180ms;
	}

	.goodbad-item--2 {
		left: 29%;
		top: 43%;
		width: 21%;
		opacity: 0.9;
		z-index: 10;
		--reveal-delay: 320ms;
	}

	.goodbad-item--3 {
		left: 52%;
		top: 33%;
		width: 21%;
		z-index: 40;
		--reveal-delay: 460ms;
	}

	.goodbad-item--4 {
		right: 6%;
		top: 14%;
		width: 20%;
		z-index: 20;
		--reveal-delay: 600ms;
	}

	.goodbad-item--5 {
		right: 5%;
		top: 3%;
		width: 23%;
		z-index: 50;
		--reveal-delay: 760ms;
	}

	.goodbad-float {
		animation-timing-function: ease-in-out;
	}

	.goodbad-float--1 {
		animation-delay: 0ms;
	}

	.goodbad-float--2 {
		animation-delay: 220ms;
	}

	.goodbad-float--3 {
		animation-delay: 420ms;
	}

	.goodbad-float--4 {
		animation-delay: 120ms;
	}

	.goodbad-float--5 {
		animation-delay: 320ms;
	}

	.goodbad-image {
		display: block;
		width: 100%;
		height: auto;
		opacity: 1;
		filter: blur(0px);
		transform: rotate(var(--goodbad-rotate, 0deg));
		transition: opacity 920ms ease-out, transform 1320ms cubic-bezier(0.16, 1, 0.3, 1), filter 1320ms ease-out;
	}

	html.goodbad-image-anim-ready .goodbad-image {
		opacity: 0;
		filter: blur(12px);
		transform: translate3d(0, 28px, 0) scale(0.96) rotate(var(--goodbad-rotate, 0deg));
	}

	html.goodbad-image-anim-ready .goodbad-image.is-loaded {
		opacity: 1;
		filter: blur(0px);
		transform: translate3d(0, 0, 0) scale(1) rotate(var(--goodbad-rotate, 0deg));
	}

	html.goodbad-image-anim-ready .goodbad-item:hover .goodbad-image.is-loaded {
		transform: translate3d(0, 0, 0) scale(1.05) rotate(var(--goodbad-rotate, 0deg));
	}

	.goodbad-image--1 {
		--goodbad-rotate: 0deg;
		border-radius: 1rem;
		box-shadow: 0 32px 72px rgba(0, 0, 0, 0.44);
	}

	.goodbad-image--2 {
		--goodbad-rotate: 0deg;
		border-radius: 1rem;
		box-shadow: 0 18px 42px rgba(0, 0, 0, 0.3);
	}

	.goodbad-image--3 {
		--goodbad-rotate: 0deg;
		border-radius: 1rem;
		box-shadow: 0 32px 72px rgba(127, 29, 29, 0.2), 0 32px 72px rgba(0, 0, 0, 0.44);
	}

	.goodbad-image--4 {
		--goodbad-rotate: 0deg;
		border-radius: 1rem;
		box-shadow: 0 32px 72px rgba(0, 0, 0, 0.44);
	}

	.goodbad-image--5 {
		--goodbad-rotate: 0deg;
		border-radius: 0.75rem;
		box-shadow: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.goodbad-image,
		.goodbad-item:hover .goodbad-image,
		.goodbad-item:hover .goodbad-image.is-loaded {
			opacity: 1;
			filter: none;
			transform: rotate(var(--goodbad-rotate, 0deg));
			transition: none;
		}
	}

	@media (max-width: 1279px) {
		.goodbad-layout {
			min-height: 0;
		}

		.goodbad-copy {
			width: min(100%, 40rem);
			margin-inline: auto;
			align-items: center;
			text-align: center;
			padding-inline: 0;
			padding-top: 0;
		}

		.goodbad-visual-layer {
			position: static;
			margin-top: clamp(2rem, 3vw, 3rem);
			transform: none;
		}

		.goodbad-visual-stage {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			grid-template-areas:
				"five five"
				"one four"
				"two three";
			row-gap: clamp(0.1rem, 0.25vw, 0.2rem);
			column-gap: clamp(0.55rem, 0.8vw, 0.85rem);
			width: min(100%, 40rem);
			margin-inline: auto;
			aspect-ratio: auto;
			padding-inline: 0;
		}

		.goodbad-item {
			position: relative;
			inset: auto;
			width: auto;
			min-width: 0;
			align-self: start;
		}

		.goodbad-item--1 {
			grid-area: one;
		}

		.goodbad-item--2 {
			grid-area: two;
		}

		.goodbad-item--3 {
			grid-area: three;
		}

		.goodbad-item--4 {
			grid-area: four;
			justify-self: stretch;
			align-self: stretch;
			height: 100%;
			width: 100%;
		}

		.goodbad-item--5 {
			grid-area: five;
			justify-self: stretch;
			align-self: stretch;
			height: 100%;
			width: 100%;
			transform: translateY(0.05rem);
		}

		.goodbad-item--4 .goodbad-float,
		.goodbad-item--5 .goodbad-float {
			height: 100%;
		}

		.goodbad-item--4 .goodbad-image,
		.goodbad-item--5 .goodbad-image {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	}

	@media (max-width: 640px) {
		.goodbad-visual-stage {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			grid-template-areas:
				"five five"
				"one four"
				"two three";
			row-gap: 0;
			column-gap: clamp(0.75rem, 2vw, 1rem);
			width: min(100%, 30rem);
			align-items: start;
		}

		.goodbad-item {
			min-width: 0;
		}

		.goodbad-item--1,
		.goodbad-item--2,
		.goodbad-item--3,
		.goodbad-item--4,
		.goodbad-item--5 {
			align-self: start;
		}

		.goodbad-item--4 {
			justify-self: stretch;
			align-self: stretch;
			height: 100%;
			width: 100%;
		}

		.goodbad-item--4 .goodbad-float {
			height: 100%;
		}

		.goodbad-item--4 .goodbad-image {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		.goodbad-item--5 {
			justify-self: stretch;
			align-self: stretch;
			height: 100%;
			width: calc(100% + 3rem);
			margin-inline: -1.5rem;
			transform: translateY(1.5rem);
		}

		.goodbad-item--5 .goodbad-float {
			height: 100%;
		}

		.goodbad-item--5 .goodbad-image {
			display: block;
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	}

	@media (max-width: 480px) {
		.goodbad-visual-stage {
			width: min(100%, 22rem);
			row-gap: 0;
			column-gap: 0.7rem;
		}

		.goodbad-item--4,
		.goodbad-item--5 {
			width: 100%;
		}

		.goodbad-item--5 {
			width: calc(100% + 2.5rem);
			margin-inline: -1.25rem;
			transform: translateY(1.25rem);
		}

		.goodbad-item--4 .goodbad-float {
			height: 100%;
		}

		.goodbad-item--4 .goodbad-image {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	}
</style>