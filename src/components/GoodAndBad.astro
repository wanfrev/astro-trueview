---
import Mockups7 from '../assets/images/Mockups7.svg';
---

<section data-bg="good-bad-2" class="section-shell py-16 md:py-24">
	<div class="mx-auto w-full max-w-[1700px]">
		<div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
			<div class="flex flex-col gap-5 md:gap-6 items-center md:items-start text-center md:text-left">
				<span class="text-[#ff5b58] font-medium text-lg" style="font-size: var(--goodandbad-label-size);">The Good and the Bad</span>

				<h2 style="font-size: var(--goodandbad-h2-size);" class="text-3xl sm:text-4xl md:text-[58px] font-bold leading-[1.08] md:leading-[1.06] tracking-[-0.03em] max-w-[620px]">
					Reading lab reports sucks. <br />
					<span class="text-white">We show you the critical information</span>
				</h2>

				<p style="font-size: var(--goodandbad-body-size);" class="text-gray-400 text-base sm:text-lg leading-relaxed max-w-md md:max-w-[520px]">
					We don’t offer you an opinion, we just show you the science.
					If a product passes or fails we show you readable lab results.
					Make healthy decisions, quickly.
				</p>
			</div>

			<div class="relative mt-2 md:mt-0">
				<img
					src={Mockups7.src ?? Mockups7}
					alt="Good and the Bad mockup"
					class="block h-auto w-full"
					style="max-width: 1512px;"
					loading="eager"
					decoding="async"
				/>
			</div>
		</div>
	</div>
</section>
