	<div class="mx-auto w-full max-w-7xl">
		<img
			src={Mockups7.src ?? Mockups7}
			alt="Good and the Bad mockup"
			class="block h-auto w-full"
			style="max-width: 1512px;"
			loading="eager"
			decoding="async"
		/>
	</div>
</section>
