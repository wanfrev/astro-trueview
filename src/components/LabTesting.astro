---
import Group from '../assets/images/group1.png';
import { Image } from 'astro:assets';

const labVisualSizes = '(max-width: 768px) 92vw, (max-width: 1280px) 52vw, 620px';
---

<section data-bg="lab" class="section-shell py-18 lg:py-24 xl:py-28">
  <div class="content-shell grid items-center gap-12 xl:grid-cols-2 xl:gap-16">
    <div data-reveal-group class="order-1 text-center xl:text-left">
      <h2 style="font-size: var(--labtesting-h2-size);" class="motion-reveal motion-reveal-left text-4xl sm:text-5xl lg:text-[48px] xl:text-[56px] font-bold leading-tight">
        We test products for <br />
        <span class="motion-word-glow motion-word-glow-red">accuracy</span>,
        <span class="motion-word-glow motion-word-glow-red">heavy metals</span>, <br />
        and <span class="motion-word-glow motion-word-glow-red">microbes</span>
      </h2>

      <p style="font-size: var(--labtesting-body-size); --reveal-delay: 120ms;" class="motion-reveal motion-reveal-left mt-8 text-gray-400 text-base sm:text-lg lg:text-xl leading-relaxed max-w-[56ch] mx-auto xl:mx-0">
        A concerning finding is the presence of a diverse array of contaminants in these products.
        This highlights the importance of thorough testing and quality control measures to ensure
        consumer safety and product purity.
      </p>

      <div class="mt-8 flex justify-center xl:hidden">
        <div class="labtesting-visual labtesting-visual-mobile">
          <Image
            src={Group}
            alt="Ilustración de resultados de laboratorio de productos"
            format="webp"
            quality={100}
            widths={[640, 900, 1200, 1600]}
            sizes={labVisualSizes}
            loading="lazy"
            decoding="async"
            style="--reveal-delay: 140ms;"
            class="motion-reveal motion-reveal-right motion-float-soft labtesting-visual-image relative z-10 drop-shadow-[0_20px_45px_rgba(0,0,0,0.38)]"
          />
        </div>
      </div>

      <div style="--reveal-delay: 220ms;" class="motion-reveal motion-reveal-left mt-10 flex justify-center xl:justify-start">
        <a href="/products" class="motion-hover-lift inline-flex items-center gap-2 bg-[#2563eb] hover:bg-blue-600 text-white px-8 py-4 rounded-full font-bold transition-all">
          Explore products
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <div class="order-2 hidden items-center justify-center xl:flex">
      <div class="labtesting-visual">
        <Image
          src={Group}
          alt="Ilustración de resultados de laboratorio de productos"
          format="webp"
          quality={100}
          widths={[640, 900, 1200, 1600]}
          sizes={labVisualSizes}
          loading="lazy"
          decoding="async"
          style="--reveal-delay: 140ms;"
          class="motion-reveal motion-reveal-right motion-float-soft labtesting-visual-image relative z-10 drop-shadow-[0_20px_45px_rgba(0,0,0,0.38)] xl:drop-shadow-[0_28px_70px_rgba(0,0,0,0.45)]"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .labtesting-visual {
    width: 100%;
    max-width: 620px;
    aspect-ratio: 620 / 520;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .labtesting-visual-mobile {
    max-width: min(100%, 420px);
    aspect-ratio: 620 / 520;
  }

  .labtesting-visual-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
