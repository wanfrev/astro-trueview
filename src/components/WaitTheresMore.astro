---
import Phones from '../assets/images/phones.png';
import Stars from '../assets/images/stars.png';
import LogoSmall from '../assets/images/logosmall.png';
import { Image } from 'astro:assets';

const waitPhonesSizes = '(max-width: 768px) 88vw, (max-width: 1280px) 64vw, 52vw';
---

<section data-bg="wait-more" class="section-shell pt-16 pb-6 md:py-28 overflow-hidden">
  <div class="max-w-[1700px] mx-auto grid md:grid-cols-[minmax(0,1.45fr)_minmax(0,0.95fr)] gap-12 md:gap-6 items-center">
    <div data-reveal-group class="relative z-20 w-full max-w-none text-center md:text-left md:pr-0">
      <span class="motion-reveal inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/8 px-4 py-2 text-[10px] sm:text-[11px] uppercase tracking-wide text-gray-200" style="font-size: var(--wait-badge-size);">
        <Image
          src={LogoSmall}
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
          class="h-2.5 w-2.5"
        />
        #1 trusted source for lab-tested supplements
      </span>

      <h2 style="font-size: var(--wait-h2-size);" class="motion-reveal motion-reveal-left mt-6 md:mt-7 text-4xl sm:text-5xl md:text-[64px] font-bold leading-[1.06] md:leading-[1.02] tracking-[-0.03em] md:tracking-[-0.035em]">
        Supplements don’t regulate
        <br />
        themselves, <span class="motion-word-glow motion-word-glow-red">so we do!</span>
      </h2>

      <p style="font-size: clamp(1.25rem, 0.95vw + 0.9rem, 2rem); --reveal-delay: 120ms;" class="motion-reveal motion-reveal-left mt-6 md:mt-8 text-gray-400 leading-[1.22] max-w-none mx-auto md:mx-0">
        Reading lab reports shouldn’t turn into a full-time job.
        <br>
        We translate complex data into Pass/Fails-covering 
        <br>
        accuracy, heavy metals,
        and microbes - just verify 
        <br>
        into your fingertips.
      </p>

      <a href="/waitlist" class="motion-reveal motion-reveal-left motion-hover-lift mt-8 md:mt-10 inline-flex items-center gap-2 rounded-full bg-[#2563eb] px-6 sm:px-8 py-3 sm:py-4 text-base sm:text-lg font-semibold text-white shadow-lg shadow-blue-900/30 transition hover:brightness-110" style="font-size: var(--wait-button-size); --reveal-delay: 220ms;">
        Join the waitlist
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="relative mt-10 min-h-80 sm:mt-14 sm:min-h-[480px] md:mt-0 md:min-h-280 overflow-visible">
      <Image
        src={Phones}
        alt="Vista previa de la app trueview en varios teléfonos"
        format="webp"
        quality={74}
        widths={[480, 720, 960, 1280, 1600]}
        sizes={waitPhonesSizes}
        loading="lazy"
        decoding="async"
        style="--reveal-delay: 160ms;"
        class="motion-reveal motion-reveal-right motion-float-soft pointer-events-none select-none absolute -right-16 -bottom-16 z-10 w-82.5 max-w-none sm:-right-3.5 sm:-bottom-12 sm:w-107.5 md:h-[1500px] md:left-auto md:-right-80 md:-top-40 md:w-200 md:translate-x-0"
      />
    </div>
  </div>
</section>
