---
import NaturalIcon from '../assets/icons/natural.svg';
import PillIcon from '../assets/icons/Pill.svg';
import PlantIcon from '../assets/icons/plant.svg';
import PoisonIcon from '../assets/icons/poison.svg';
import { Image } from 'astro:assets';

const cards = [
  { name: 'Protein', percentage: '70%', icon: PillIcon },
  { name: 'Super Greens', percentage: '75%', icon: PlantIcon },
  { name: 'Prenatal', percentage: '19%', icon: NaturalIcon },
  { name: 'Herbal Supplements', percentage: '38%', icon: PoisonIcon },
];

---

<section class="section-shell py-16 md:py-28">
  <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute left-[45%] top-1/2 h-[420px] w-[420px] -translate-y-1/2 rounded-full bg-purple-900/20 blur-[160px]"></div>
    <div class="absolute right-[10%] top-[18%] h-[320px] w-[320px] rounded-full bg-blue-900/12 blur-[150px]"></div>
  </div>

  <div class="max-w-[1700px] mx-auto grid gap-10 md:grid-cols-[minmax(0,1fr)_minmax(0,560px)] items-center">
    <h2 class="max-w-[620px] text-3xl sm:text-4xl md:text-[48px] font-bold leading-[1.08] md:leading-[1.06] tracking-[-0.03em] text-center md:text-left">
      We have lab tested many
      products and what we have
      found is <span class="text-[#ff5b58]">alarming</span>
    </h2>

    <div class="grid grid-cols-2 gap-4 sm:gap-6">
      {cards.map((card) => (
        <div class="bg-[#24252a] rounded-2xl p-5 sm:p-6 flex flex-col justify-between w-full aspect-[2/1] min-h-[120px] shadow-lg">
          
          <div class="flex justify-between items-start">
            <div class="flex items-baseline gap-1.5 sm:gap-2 pt-1 sm:pt-2">
              <span class="text-[#e74c4e] text-3xl md:text-[42px] font-bold tracking-tight leading-none">{card.percentage}</span>
              <span class="text-[#e74c4e] text-sm md:text-base font-medium leading-none">Failed</span>
            </div>
            
            <div class="w-12 h-12 md:w-14 md:h-14 bg-white/5 border border-white/5 flex items-center justify-center shrink-0 rounded-tl-sm rounded-br-sm rounded-tr-2xl rounded-bl-2xl">
              <Image src={card.icon} alt={`${card.name} icon`} class="w-6 h-6 md:w-8 md:h-8" />
            </div>
          </div>

          <div class="mt-4">
            <h3 class="text-white text-base md:text-lg font-medium tracking-wide">
              {card.name}
            </h3>
          </div>
          
        </div>
      ))}
    </div>
  </div>
</section>
