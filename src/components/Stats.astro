---
import NaturalIcon from '../assets/icons/natural.svg';
import PillIcon from '../assets/icons/Pill.svg';
import PlantIcon from '../assets/icons/plant.svg';
import PoisonIcon from '../assets/icons/poison.svg';
import { Image } from 'astro:assets';

const cards = [
  { name: 'Protein', percentage: '70%', icon: PoisonIcon },
  { name: 'Super Greens', percentage: '75%', icon: PlantIcon },
  { name: 'Prenatal', percentage: '19%', icon: NaturalIcon },
  { name: 'Herbal Supplements', percentage: '38%', icon: PillIcon },
];

---

<section data-bg="stats" class="section-shell py-16 lg:py-24 xl:py-28">
  <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute left-[45%] top-1/2 h-80 w-80 -translate-y-1/2 rounded-full bg-purple-900/16 blur-[120px] lg:h-105 lg:w-105 lg:blur-[160px]"></div>
    <div class="absolute right-[10%] top-[18%] h-60 w-60 rounded-full bg-blue-900/10 blur-[110px] lg:h-80 lg:w-80 lg:blur-[150px]"></div>
  </div>

  <div class="stats-layout content-shell">
    <h2 class="stats-heading motion-reveal motion-reveal-left max-w-[23ch] text-3xl sm:text-4xl lg:text-[44px] xl:text-[52px] font-bold leading-[1.08] lg:leading-[1.06] tracking-[-0.03em] text-center lg:text-left">
      We have lab tested many
      products and what we have
      found is <span class="motion-word-glow motion-word-glow-red">alarming</span>
    </h2>

    <div class="stats-cards-shell">
      <div data-reveal-group class="stats-cards">
        {cards.map((card, index) => {
          const cardDirection = index < 2 ? 'stats-card--up' : 'stats-card--down';

          return (
            <div class={`motion-reveal motion-reveal-zoom motion-hover-lift stats-card glass-element ${cardDirection} p-5 sm:p-6 flex flex-col justify-between card shadow-[0_16px_36px_rgba(0,0,0,0.28)] xl:shadow-[0_26px_52px_rgba(0,0,0,0.38)]`}>
              <div class="flex justify-between items-start">
                <div class="flex items-baseline gap-1.5 sm:gap-2 pt-1 sm:pt-2">
                  <span class="text-[#e74c4e] text-3xl lg:text-[38px] xl:text-[42px] font-bold tracking-tight leading-none">{card.percentage}</span>
                  <span class="text-[#e74c4e] text-sm lg:text-base font-medium leading-none">Failed</span>
                </div>

                <div class="w-12 h-12 md:w-14 md:h-14 bg-white/5 border border-white/5 flex items-center justify-center shrink-0 rounded-tl-sm rounded-br-sm rounded-tr-2xl rounded-bl-2xl">
                  <Image src={card.icon} alt={`${card.name} icon`} class="w-6 h-6 md:w-8 md:h-8" />
                </div>
              </div>

              <div class="mt-1">
                <h3 class="text-white text-base md:text-lg font-small tracking-wide">
                  {card.name}
                </h3>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .stats-card {
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 260ms ease;
    will-change: transform;
  }

  .glass-element {
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
  }

  .stats-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .stats-heading {
    margin-inline: auto;
    text-align: center;
  }

  .stats-cards-shell {
    display: flex;
    justify-content: center;
  }

  .stats-cards {
    width: 100%;
    max-width: 450px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (hover: hover) and (pointer: fine) {
    .stats-card--up:hover {
      transform: translate3d(0, -14px, 0);
      box-shadow: 0 26px 52px rgba(0, 0, 0, 0.42);
    }

    .stats-card--down:hover {
      transform: translate3d(0, 14px, 0);
      box-shadow: 0 26px 52px rgba(0, 0, 0, 0.42);
    }
  }

  .stats-card:focus-within {
    transform: translate3d(0, -6px, 0);
  }

  @media (min-width: 640px) {
    .stats-cards {
      max-width: 760px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .stats-layout {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: 3rem;
    }

    .stats-heading {
      margin-inline: 0;
      text-align: left;
    }

    .stats-cards-shell {
      justify-content: flex-start;
    }

    .stats-cards {
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stats-card {
      transition: none;
    }

    .stats-card--up:hover,
    .stats-card--down:hover,
    .stats-card:focus-within {
      transform: none;
    }
  }
</style>
