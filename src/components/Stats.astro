---
const stats = [
  {
    percent: '70%',
    label: 'Protein',
    icon: 'bottle'
  },
  {
    percent: '75%',
    label: 'Super Greens',
    icon: 'flask'
  },
  {
    percent: '19%',
    label: 'Prenatal',
    icon: 'sprout'
  },
  {
    percent: '38%',
    label: 'Herbal Supplements',
    icon: 'capsule'
  }
];
---

<section class="section-shell py-24 md:py-28">
  <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute left-[45%] top-1/2 h-[420px] w-[420px] -translate-y-1/2 rounded-full bg-purple-900/20 blur-[160px]"></div>
    <div class="absolute right-[10%] top-[18%] h-[320px] w-[320px] rounded-full bg-blue-900/12 blur-[150px]"></div>
  </div>

  <div class="max-w-[1320px] mx-auto grid md:grid-cols-[minmax(0,1fr)_minmax(0,560px)] gap-12 md:gap-16 items-center">
    <h2 class="max-w-[620px] text-5xl md:text-[58px] font-bold leading-[1.06] tracking-[-0.03em]">
      We have lab tested many
      <br />
      products and what we have
      <br />
      found is <span class="text-[#ff5b58]">alarming</span>
    </h2>

      <div class="grid grid-cols-2 gap-5 md:gap-6">
      {stats.map((stat) => (
          <article class="relative min-h-[116px] rounded-[1.4rem] border border-white/8 bg-[#37323d]/90 px-5 py-5 shadow-[0_10px_40px_rgba(0,0,0,0.20)]">
          <div class="absolute right-4 top-4 h-12 w-12 rounded-2xl border border-white/10 bg-[#4a4551]/70 flex items-center justify-center">
            {stat.icon === 'bottle' && (
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-white/65" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M9 4h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M10 4v2l-2 2v2.5c0 .8-.3 1.5-.8 2.1L6 13.3c-.7.7-1 1.6-1 2.6V20h14v-4.1c0-1-.4-1.9-1-2.6l-1.2-1.2c-.5-.6-.8-1.3-.8-2.1V8l-2-2V4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M8.2 13.5h7.6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M9.6 15.8h4.8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}

            {stat.icon === 'flask' && (
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-white/65" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M9 3h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M11 3v4.2L6.8 14a3 3 0 0 0 2.5 4.7h5.4A3 3 0 0 0 17.2 14L13 7.2V3" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M9.6 13.6h4.8M8.5 16h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}

            {stat.icon === 'sprout' && (
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-white/65" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 19V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M12 13c-4.2 0-6.5-2.2-7-7 4.8.5 7 2.8 7 7Z" fill="currentColor"/>
                <path d="M12 13c4.2 0 6.5-2.2 7-7-4.8.5-7 2.8-7 7Z" fill="currentColor"/>
              </svg>
            )}

            {stat.icon === 'capsule' && (
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-white/65" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8.4 7.4a4 4 0 1 1 5.7 5.7l-4.3 4.3a4 4 0 0 1-5.7-5.7l4.3-4.3Z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9.3 8.3 15 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
          </div>

          <div class="pr-14">
            <div class="flex items-end gap-2.5">
              <span class="text-[42px] leading-none font-bold tracking-[-0.03em] text-[#ff5b58]">{stat.percent}</span>
              <span class="pb-[4px] text-[28px] leading-none font-semibold text-[#ff5b58]">Failed</span>
            </div>

            <p class="mt-5 text-[17px] leading-none text-white">{stat.label}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
