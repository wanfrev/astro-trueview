---
import HerbalFailed from '../assets/HerbalFailed.png';
import PrenatalFailed from '../assets/PrenatalFailed.png';
import SuperGreensFailed from '../assets/SuperGreensFailed.png';

const cards = [
  { src: HerbalFailed.src, alt: 'Protein card' },
  { src: SuperGreensFailed.src, alt: 'Super Greens card' },
  { src: PrenatalFailed.src, alt: 'Prenatal card' },
  { src: HerbalFailed.src, alt: 'Herbal Supplements card' },
];
---

<section class="section-shell py-24 md:py-28">
  <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute left-[45%] top-1/2 h-[420px] w-[420px] -translate-y-1/2 rounded-full bg-purple-900/20 blur-[160px]"></div>
    <div class="absolute right-[10%] top-[18%] h-[320px] w-[320px] rounded-full bg-blue-900/12 blur-[150px]"></div>
  </div>

  <div class="max-w-[1320px] mx-auto grid md:grid-cols-[minmax(0,1fr)_minmax(0,560px)] items-center">
    <h2 class="max-w-[620px] text-5xl md:text-[48px] font-bold leading-[1.06] tracking-[-0.03em]">
      We have lab tested many
      products and what we have
      found is <span class="text-[#ff5b58]">alarming</span>
    </h2>

    <div class="grid grid-cols-2 gap-5 md:gap-6">
      {cards.map((card) => (
        <img src={card.src} alt={card.alt} class="block w-full h-auto" />
      ))}
    </div>
  </div>
</section>
