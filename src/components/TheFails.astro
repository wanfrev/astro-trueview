---
import PhoneTop from '../assets/phonecaution2.png';
import PhoneBottom from '../assets/phone3.png';
import VioletBottle from '../assets/violetbottle.png';
import VioletBottle2 from '../assets/violetbottle2.png';
import Pill from '../assets/pill.png';
import GreyBottle from '../assets/greybottle.png';
import { Image } from 'astro:assets';
---

<section class="section-shell py-24">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
    <div class="relative h-full min-h-[420px] md:min-h-[920px] overflow-visible">
      <div aria-hidden="true" class="absolute inset-0 rounded-full bg-[radial-gradient(circle_at_40%_45%,rgba(255,91,88,0.28),transparent_40%),radial-gradient(circle_at_50%_58%,rgba(173,29,255,0.22),transparent_55%)] blur-[6px]"></div>

      <Image src={PhoneTop} alt="" aria-hidden="true" class="absolute left-[12%] top-[12%] z-10 w-auto max-w-none" />
      <Image src={PhoneBottom} alt="" aria-hidden="true" class="absolute left-[20%] top-[34%] z-10 w-auto max-w-none" />

      <Image src={VioletBottle} alt="" aria-hidden="true" class="absolute left-[80%] top-[8%] z-20 w-auto max-w-none opacity-75" />
      <Image src={VioletBottle2} alt="" aria-hidden="true" class="absolute left-[89.7%] top-[13.5%] z-20 w-auto max-w-none opacity-75" />

      <Image src={Pill} alt="" aria-hidden="true" class="absolute left-[15%] bottom-[12%] z-20 w-auto max-w-none opacity-60" />
      <Image src={GreyBottle} alt="" aria-hidden="true" class="absolute left-[5%] bottom-[11%] z-20 w-auto max-w-none opacity-85" />
    </div>

    <div class="flex flex-col gap-6 md:items-end md:text-right">
      <span class="text-[#ff5b58] font-medium text-lg">The Fails</span>

      <h2 class="text-4xl md:text-[58px] font-bold leading-[1.06] tracking-[-0.03em] max-w-[620px]">
        Reading lab reports is difficult. <br />
        <span class="text-white">We show you the critical information. Quickly.</span>
      </h2>

      <p class="text-gray-400 text-lg leading-relaxed max-w-md md:max-w-[520px]">
        We don't offer you an opinion, we just show you the science.
        If a product passes or fails we show you readable lab results.
        Make healthy decisions, quickly.
      </p>
    </div>
  </div>
</section>
