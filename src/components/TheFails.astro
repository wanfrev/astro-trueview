---
import PhoneTop from '../assets/images/phonecaution2.png';
import PhoneBottom from '../assets/images/phone3.png';
import VioletBottle from '../assets/icons/violetbottle.png';
import VioletBottle2 from '../assets/icons/violetbottle2.png';
import Pill from '../assets/icons/pill.png';
import GreyBottle from '../assets/icons/greybottle.png';
import { Image } from 'astro:assets';
---

<section data-bg="fails" data-thefails-root data-thefails-in-view="false" class="section-shell py-14 md:py-20">
  <div class="max-w-[1700px] mx-auto grid md:grid-cols-2 gap-10 md:gap-16 items-center">
    <div class="relative h-full min-h-[420px] sm:min-h-[560px] md:min-h-[920px] overflow-visible">
      <div aria-hidden="true" class="hidden"></div>

      <Image src={PhoneTop} alt="" aria-hidden="true" class="thefails-phone thefails-phone-top absolute left-[8%] top-[8%] z-30 w-[70%] max-w-[300px] sm:left-[10%] sm:w-[66%] sm:max-w-[360px] md:left-[12%] md:top-[12%] md:w-auto md:max-w-none" />
      <Image src={PhoneBottom} alt="" aria-hidden="true" class="thefails-phone thefails-phone-bottom absolute left-[34%] top-[34%] z-10 w-[62%] max-w-[280px] sm:left-[28%] sm:w-[60%] sm:max-w-[340px] md:left-[20%] md:top-[34%] md:w-auto md:max-w-none" />

      <Image src={VioletBottle} alt="" aria-hidden="true" class="absolute left-[76%] top-[8%] z-20 w-[44px] sm:w-auto md:left-[80%] md:w-auto max-w-none opacity-75" />
      <Image src={VioletBottle2} alt="" aria-hidden="true" class="absolute left-[85%] top-[12%] z-20 w-[40px] sm:w-auto md:left-[89.7%] md:top-[13.5%] max-w-none opacity-75" />

      <Image src={Pill} alt="" aria-hidden="true" class="absolute left-[12%] bottom-[8%] z-20 w-[44px] sm:w-auto md:left-[15%] md:bottom-[12%] max-w-none opacity-60" />
      <Image src={GreyBottle} alt="" aria-hidden="true" class="absolute left-[2%] bottom-[8%] z-20 w-[44px] sm:w-auto md:left-[5%] md:bottom-[11%] max-w-none opacity-85" />
    </div>

    <div class="flex flex-col gap-5 md:gap-6 items-center text-center md:items-end md:text-right">
      <span class="text-[#ff5b58] font-medium text-lg" style="font-size: var(--thefails-label-size);">The Fails</span>

      <h2 style="font-size: var(--thefails-h2-size);" class="text-3xl sm:text-4xl md:text-[40px] font-bold leading-[1.08] md:leading-[1.06] tracking-[-0.03em] max-w-[620px]">
        Reading lab reports is difficult. <br />
        <span class="text-white">We show you the critical information. Quickly.</span>
      </h2>

      <p style="font-size: var(--thefails-body-size);" class="text-gray-400 text-base sm:text-lg leading-relaxed max-w-md md:max-w-[520px]">
        We don't offer you an opinion, we just show you the science.
        If a product passes or fails we show you readable lab results.
        Make healthy decisions, quickly.
      </p>
    </div>
  </div>
</section>

<style>
  .thefails-phone {
    will-change: transform;
    animation-duration: 3.8s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-direction: alternate;
    animation-play-state: paused;
  }

  .thefails-phone-top {
    animation-name: thefailsFloatUp;
  }

  .thefails-phone-bottom {
    animation-name: thefailsFloatDown;
  }

  [data-thefails-root][data-thefails-in-view='true'] .thefails-phone {
    animation-play-state: running;
  }

  @keyframes thefailsFloatUp {
    from { transform: translate3d(0, 6px, 0); }
    to { transform: translate3d(0, -14px, 0); }
  }

  @keyframes thefailsFloatDown {
    from { transform: translate3d(0, -6px, 0); }
    to { transform: translate3d(0, 14px, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .thefails-phone {
      animation: none !important;
      transform: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const sections = document.querySelectorAll('[data-thefails-root]');

    sections.forEach((section) => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            section.setAttribute('data-thefails-in-view', entry.isIntersecting ? 'true' : 'false');
          });
        },
        {
          threshold: 0.35,
        }
      );

      observer.observe(section);
    });
  })();
</script>
