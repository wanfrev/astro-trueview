---
import ZincPhone from '../assets/zinc.png';
import ZincCard1 from '../assets/zinccard1.png';
import ZincCard2 from '../assets/zinccard2.png';
import ZincCard3 from '../assets/zinccard3.png';
import ZincCard4 from '../assets/zinccard4.png';
import { Image } from 'astro:assets';
---

<section class="section-shell py-16 md:py-24">
  <div class="mx-auto grid max-w-7xl items-center gap-10 md:gap-16 md:grid-cols-2">
    <div class="order-1 max-w-xl text-center md:text-left mx-auto md:mx-0">
      <span class="mb-4 block text-lg font-medium text-[#2563eb]">The Good and the Bad</span>

      <h2 class="text-3xl sm:text-4xl font-bold leading-tight md:text-5xl">
        Reading lab reports sucks. <br />
        <span class="text-white/90">We show you the critical information.</span>
      </h2>

      <p class="mt-6 md:mt-8 max-w-lg text-base sm:text-lg leading-relaxed text-gray-400 mx-auto md:mx-0">
        We don’t offer you an opinion, we just show you the science.
        If a product passes or fails we show you readable lab results.
        Make healthy decisions, quickly.
      </p>
    </div>

    <div class="order-2">
      <div class="relative mx-auto h-[520px] sm:h-[620px] md:h-[700px] w-full max-w-[720px] overflow-visible">
        <div aria-hidden="true" class="absolute left-1/2 top-1/2 h-[520px] w-[520px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,_rgba(37,99,235,0.28)_0%,_rgba(24,24,84,0.14)_45%,_transparent_75%)] blur-[120px]"></div>

        <Image
          src={ZincPhone}
          alt="Nature's Bounty Zinc 50mg lab result"
          class="absolute left-1/2 top-0 z-10 h-auto w-[260px] -translate-x-1/2 drop-shadow-[0_36px_80px_rgba(0,0,0,0.5)] sm:w-[320px] md:left-[140px] md:w-auto md:translate-x-0"
        />

        <Image
          src={ZincCard3}
          alt="Heavy Metals Passed"
          class="absolute right-[2%] top-[74px] z-20 h-auto w-[120px] drop-shadow-[0_18px_30px_rgba(0,0,0,0.35)] sm:w-auto md:left-[448px] md:right-auto md:top-[100px]"
        />

        <Image
          src={ZincCard4}
          alt="Microbiological 7/7 Passed"
          class="absolute left-[6%] top-[300px] z-20 h-auto w-[160px] drop-shadow-[0_18px_30px_rgba(0,0,0,0.35)] sm:top-[370px] sm:w-auto md:left-[55px] md:top-[408px]"
        />

        <Image
          src={ZincCard2}
          alt="Potency Claim"
          class="absolute left-[2%] top-[356px] z-20 h-auto w-[170px] drop-shadow-[0_18px_30px_rgba(0,0,0,0.35)] sm:top-[460px] sm:w-auto md:left-[25px] md:top-[490px]"
        />

        <Image
          src={ZincCard1}
          alt="Contaminants Detected: 0"
          class="absolute right-[4%] top-[206px] z-20 h-auto w-[170px] drop-shadow-[0_18px_30px_rgba(0,0,0,0.35)] sm:w-auto md:left-[400px] md:right-auto md:top-[245px]"
        />
      </div>
    </div>
  </div>
</section>
