---
import ZincPhone from '../assets/images/zinc.png';
import { Image } from 'astro:assets';
---

<section data-bg="good-bad" data-gabfirst-root data-gabfirst-in-view="false" class="section-shell py-16 lg:py-24">
  <div class="content-shell grid items-center gap-10 xl:gap-16 xl:grid-cols-2">
    <div data-reveal-group class="order-1 max-w-[56ch] text-center xl:text-left mx-auto xl:mx-0">
      <span class="motion-reveal motion-reveal-impact motion-word-glow motion-word-glow-blue mb-4 block text-lg lg:text-xl font-black tracking-[-0.02em] text-[#2563eb]" style="font-size: var(--goodandbad-label-size);">The Good and the Bad</span>

      <h2 style="font-size: var(--goodandbad-h2-size);" class="motion-reveal motion-reveal-impact motion-reveal-left text-3xl sm:text-4xl lg:text-[48px] xl:text-[56px] font-bold leading-tight">
        Reading lab reports sucks. <br />
        <span class="text-white/90">We show you the critical information.</span>
      </h2>

      <p style="font-size: var(--goodandbad-body-size); --reveal-delay: 120ms;" class="motion-reveal motion-reveal-impact motion-reveal-left mt-6 lg:mt-8 max-w-lg text-base sm:text-lg lg:text-xl leading-relaxed text-gray-400 mx-auto lg:mx-0">
        We don’t offer you an opinion, we just show you the science.
        If a product passes or fails we show you readable lab results.
        Make healthy decisions, quickly.
      </p>
    </div>

    <div class="order-2 flex justify-center xl:justify-start">
      <div class="gabfirst-visual">
        <div aria-hidden="true" class="hidden"></div>

        <div class="gabfirst-stage">
          <Image
            src={ZincPhone}
            alt="Nature's Bounty Zinc 50mg lab result"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            style="--reveal-delay: 80ms; --reveal-duration: 1600ms;"
            class="motion-reveal motion-reveal-right gabfirst-phone"
          />

          <div
            class="gabfirst-card gabfirst-card-1"
            aria-label="Heavy Metals Passed"
          >
            <div class="h-full w-full rounded-[20px] bg-[#d1d5db] flex flex-col items-center justify-center px-3 sm:px-4">
              <div class="h-6 w-6 sm:h-8 sm:w-8 rounded-full bg-[#11a821] flex items-center justify-center">
                <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="mt-2 sm:mt-3 text-center text-[11px] sm:text-[13px] lg:text-[13px] text-[#11a821] font-medium leading-tight tracking-[-0.01em] px-1">
                Heavy Metals Passed
              </p>
            </div>
          </div>

          <div
            class="gabfirst-card gabfirst-card-2"
            aria-label="Microbiological 7/7 Passed"
          >
            <div class="h-full w-full rounded-[20px] bg-[#d1d5db] flex items-center px-3 sm:px-5">
              <div class="h-5 w-5 sm:h-7 sm:w-7 rounded-full bg-[#bde7c4] flex items-center justify-center shrink-0">
                <svg class="h-3 w-3 sm:h-4 sm:w-4 text-[#11a821]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="ml-2 sm:ml-3 text-[#11a821] text-[10px] sm:text-[12px] lg:text-[12px] font-medium leading-tight tracking-[-0.01em] whitespace-normal wrap-break-word">
                Microbiological 7/7 Passed
              </p>
            </div>
          </div>

          <div
            class="gabfirst-card gabfirst-card-3"
            aria-label="Potency Claim"
          >
            <div class="h-full w-full rounded-[20px] bg-[#d1d5db] flex flex-col items-center justify-center px-3 sm:px-4">
              <div class="h-6 w-6 sm:h-8 sm:w-8 rounded-full bg-[#11a821] flex items-center justify-center">
                <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="mt-2 sm:mt-3 text-center text-[#11a821] text-[11px] sm:text-[13px] lg:text-[13px] font-medium leading-tight tracking-[-0.01em] px-1">
                Potency Claim
              </p>
            </div>
          </div>

          <div
            class="gabfirst-card gabfirst-card-4"
            aria-label="Contaminants Detected: 0"
          >
            <div class="h-full w-full rounded-[20px] bg-[#d1d5db] flex items-center px-3 sm:px-5">
              <div class="h-5 w-5 sm:h-7 sm:w-7 rounded-full bg-[#bde7c4] flex items-center justify-center shrink-0">
                <svg class="h-3 w-3 sm:h-4 sm:w-4 text-[#11a821]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="ml-2 sm:ml-3 text-[#11a821] text-[10px] sm:text-[12px] lg:text-[12px] font-medium leading-tight tracking-[-0.01em] whitespace-normal wrap-break-word">
                Contaminants Detected: 0
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gabfirst-visual {
    position: relative;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 400 / 540;
    margin-inline: auto;
    overflow: visible;
    z-index: 1;
  }

  .gabfirst-stage {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform-origin: center center;
  }

  /* Background gradient reveal: appears first */
  [data-gabfirst-root] {
    position: relative;
    overflow: visible;
  }

  [data-gabfirst-root]::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    background: linear-gradient(180deg, rgba(37,99,235,0.06) 0%, rgba(0,0,0,0.55) 100%);
    transition: opacity 480ms ease;
  }

  [data-gabfirst-root][data-gabfirst-in-view='true']::before {
    opacity: 1;
    transition-delay: 0ms;
  }

  .gabfirst-phone {
    position: absolute;
    left: 11%;
    top: 0;
    width: 85%;
    height: auto;
    z-index: 10;
    box-shadow: 0 36px 80px rgba(0, 0, 0, 0.5);
  }

  .gabfirst-card {
    position: absolute;
    opacity: 0;
    --gab-card-enter-x: 0px;
    --gab-card-enter-y: 10px;
    transform: translate3d(var(--gab-card-enter-x), var(--gab-card-enter-y), 0) scale(0.96);
    transition-property: opacity, transform;
    transition-duration: 1400ms;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
    z-index: 20;
    box-shadow: 0 18px 30px rgba(0, 0, 0, 0.35);
    border-radius: 12px;
    overflow: hidden;
    background: #d1d5db;
  }

  .gabfirst-card-1 {
    right: 1%;
    top: 13.7%;
    width: 30.5%;
    aspect-ratio: 122 / 86;
    --gab-card-enter-x: 56px;
    transition-delay: 900ms;
  }

  .gabfirst-card-2 {
    left: -5%;
    top: 60%;
    width: 41.9%;
    aspect-ratio: 168 / 58;
    --gab-card-enter-x: -62px;
    transition-delay: 1080ms;
  }

  .gabfirst-card-3 {
    left: -3%;
    top: 73%;
    width: 36%;
    aspect-ratio: 144 / 104;
    --gab-card-enter-x: -44px;
    transition-delay: 1260ms;
  }

  .gabfirst-card-4 {
    right: -5%;
    top: 35%;
    width: 44.5%;
    aspect-ratio: 178 / 58;
    --gab-card-enter-x: 66px;
    transition-delay: 1440ms;
  }

  .gabfirst-card > div {
    height: 100%;
    width: 100%;
    border-radius: inherit;
    background: transparent;
    overflow: hidden;
  }

  [data-gabfirst-root][data-gabfirst-in-view='true'] .gabfirst-card {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media (min-width: 1280px) {
    .gabfirst-visual {
      margin-inline: 0;
    }

    .gabfirst-stage {
      transform-origin: left center;
      transform: scale(0.9) translateX(-10%);
    }
  }

  @media (min-width: 1536px) {
    .gabfirst-stage {
      transform: scale(1);
    }
  }

  @media (min-width: 1792px) {
    .gabfirst-stage {
      transform: scale(1.05);
    }
  }

  @media (max-width: 1023px) {
    .gabfirst-visual {
      max-width: 450px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gabfirst-card {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const sections = document.querySelectorAll('[data-gabfirst-root]');

    sections.forEach((section) => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              section.setAttribute('data-gabfirst-in-view', 'true');
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.3,
        }
      );

      observer.observe(section);
    });
  })();
</script>
