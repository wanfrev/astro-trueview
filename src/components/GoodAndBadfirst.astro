---
import ZincPhone from '../assets/images/zinc.png';
import { Image } from 'astro:assets';
---

<section data-bg="good-bad" data-gabfirst-root data-gabfirst-in-view="false" class="section-shell py-16 lg:py-24">
  <div class="content-shell grid items-center gap-10 lg:gap-16 lg:grid-cols-2">
    <div class="order-2 lg:order-1 max-w-[56ch] text-center lg:text-left mx-auto lg:mx-0">
      <span class="mb-4 block text-lg lg:text-xl font-medium text-[#2563eb]" style="font-size: var(--goodandbad-label-size);">The Good and the Bad</span>

      <h2 style="font-size: var(--goodandbad-h2-size);" class="text-3xl sm:text-4xl lg:text-[48px] xl:text-[56px] font-bold leading-tight">
        Reading lab reports sucks. <br />
        <span class="text-white/90">We show you the critical information.</span>
      </h2>

      <p style="font-size: var(--goodandbad-body-size);" class="mt-6 lg:mt-8 max-w-lg text-base sm:text-lg lg:text-xl leading-relaxed text-gray-400 mx-auto lg:mx-0">
        We don’t offer you an opinion, we just show you the science.
        If a product passes or fails we show you readable lab results.
        Make healthy decisions, quickly.
      </p>
    </div>

    <div class="order-1 lg:order-2">
      <div class="relative mx-auto h-[520px] sm:h-[620px] lg:h-[640px] xl:h-[700px] w-full max-w-[720px] overflow-visible">
        <div aria-hidden="true" class="hidden"></div>

        <div class="absolute inset-0 origin-center lg:origin-left lg:scale-[0.9] xl:scale-100 2xl:scale-[1.05]">
          <Image
            src={ZincPhone}
            alt="Nature's Bounty Zinc 50mg lab result"
            class="absolute left-1/2 top-0 z-10 h-auto w-[260px] -translate-x-1/2 drop-shadow-[0_36px_80px_rgba(0,0,0,0.5)] sm:w-[320px] lg:left-[20%] lg:w-auto lg:translate-x-0"
          />

          <div
            class="gabfirst-card gabfirst-card-1 absolute right-[2%] top-[74px] z-20 w-[86px] h-[67px] drop-shadow-[0_18px_30px_rgba(0,0,0,0.35)] sm:w-[170px] sm:h-[132px] lg:left-[69%] lg:right-auto lg:top-[14%]"
            aria-label="Heavy Metals Passed"
          >
            <div class="h-full w-full rounded-[20px] bg-[#d1d5db] flex flex-col items-center justify-center px-3 sm:px-4">
              <div class="h-7 w-7 sm:h-8 sm:w-8 rounded-full bg-[#11a821] flex items-center justify-center">
                <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="mt-2 sm:mt-3 text-center text-[9px] sm:text-[13px] lg:text-[13px] text-[#11a821] font-medium leading-tight tracking-[-0.01em]">
                Heavy Metals Passed
              </p>
            </div>
          </div>

          <div
            class="gabfirst-card gabfirst-card-2 absolute left-[6%] top-[300px] z-20 w-[115px] h-[44px] drop-shadow-[0_18px_30px_rgba(0,0,0,0.35)] sm:top-[370px] sm:w-[250px] sm:h-[69px] lg:left-[13%] lg:top-[58%]"
            aria-label="Microbiological 7/7 Passed"
          >
            <div class="h-full w-full rounded-[20px] bg-[#d1d5db] flex items-center px-3 sm:px-5">
              <div class="h-5 w-5 sm:h-7 sm:w-7 rounded-full bg-[#bde7c4] flex items-center justify-center shrink-0">
                <svg class="h-3 w-3 sm:h-4 sm:w-4 text-[#11a821]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="ml-2 sm:ml-3 text-[#11a821] text-[8px] sm:text-[12px] lg:text-[12px] font-medium leading-none tracking-[-0.01em] whitespace-nowrap">
                Microbiological 7/7 Passed
              </p>
            </div>
          </div>

          <div
            class="gabfirst-card gabfirst-card-3 absolute left-[2%] top-[356px] z-20 w-[122px] h-[95px] drop-shadow-[0_18px_30px_rgba(0,0,0,0.35)] sm:top-[460px] sm:w-[180px] sm:h-[120px] lg:left-[9.5%] lg:top-[71%]"
            aria-label="Potency Claim"
          >
            <div class="h-full w-full rounded-[20px] bg-[#d1d5db] flex flex-col items-center justify-center px-3 sm:px-4">
              <div class="h-7 w-7 sm:h-8 sm:w-8 rounded-full bg-[#11a821] flex items-center justify-center">
                <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="mt-2 sm:mt-3 text-center text-[#11a821] text-[10px] sm:text-[13px] lg:text-[13px] font-medium leading-tight tracking-[-0.01em]">
                Potency Claim
              </p>
            </div>
          </div>

          <div
            class="gabfirst-card gabfirst-card-4 absolute right-[4%] top-[206px] z-20 w-[122px] h-[47px] drop-shadow-[0_18px_30px_rgba(0,0,0,0.35)] sm:w-[265px] sm:h-[65px] lg:left-[58%] lg:right-auto lg:top-[35%]"
            aria-label="Contaminants Detected: 0"
          >
            <div class="h-full w-full rounded-[20px] bg-[#d1d5db] flex items-center px-3 sm:px-5">
              <div class="h-5 w-5 sm:h-7 sm:w-7 rounded-full bg-[#bde7c4] flex items-center justify-center shrink-0">
                <svg class="h-3 w-3 sm:h-4 sm:w-4 text-[#11a821]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="ml-2 sm:ml-3 text-[#11a821] text-[8px] sm:text-[12px] lg:text-[12px] font-medium leading-none tracking-[-0.01em] whitespace-nowrap">
                Contaminants Detected: 0
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gabfirst-card {
    opacity: 0;
    transform: translate3d(0, 18px, 0) scale(0.96);
    transition-property: opacity, transform;
    transition-duration: 920ms;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  .gabfirst-card-1 { transition-delay: 140ms; }
  .gabfirst-card-2 { transition-delay: 340ms; }
  .gabfirst-card-3 { transition-delay: 540ms; }
  .gabfirst-card-4 { transition-delay: 740ms; }

  [data-gabfirst-root][data-gabfirst-in-view='true'] .gabfirst-card {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .gabfirst-card {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const sections = document.querySelectorAll('[data-gabfirst-root]');

    sections.forEach((section) => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              section.setAttribute('data-gabfirst-in-view', 'true');
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.3,
        }
      );

      observer.observe(section);
    });
  })();
</script>
