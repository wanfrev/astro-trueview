---
import logoIcon from "../assets/icons/Logo.svg?url";
import socialLinksIcon from "../assets/icons/Social Links.svg?url";
import emailIcon from "../assets/icons/email-icon.svg?url";
import mobileIcon from "../assets/icons/Mobile.svg?url";
import locationIcon from "../assets/icons/location-icon.svg?url";
import sendIcon from "../assets/icons/Vector.svg?url";
---

<section class="section-shell no-section-gap px-6 lg:px-12 bg-black">
  <footer data-reveal-group class="content-shell border-t border-white/10 pt-8 md:pt-12 pb-6 md:pb-8 grid gap-8 md:grid-cols-4 md:gap-10 text-sm text-gray-300">
    <div class="motion-reveal motion-reveal-left flex flex-col gap-6 justify-between h-full">
      <div>
        <div class="w-[120px]">
          <img src={logoIcon} alt="trueview logo" width="120" height="35" class="w-full h-auto" />
        </div>
        <p class="mt-6 text-white">Copyright © 2025 trueview.</p>
        <p class="text-white">All rights reserved</p>
      </div>
      <div class="mt-4">
        <a href="#" class="inline-block">
          <img src={socialLinksIcon} alt="Instagram" width="32" height="32" class="w-8 h-8" />
        </a>
      </div>
    </div>

    <div class="motion-reveal">
      <h4 class="text-white font-semibold mb-4 text-lg md:text-xl">Quick links</h4>
      <ul class="space-y-3 text-white/40">
        <li><a href="#" class="motion-hover-lift inline-flex hover:text-white transition">Home</a></li>
        <li><a href="#" class="motion-hover-lift inline-flex hover:text-white transition">About</a></li>
        <li><a href="#" class="motion-hover-lift inline-flex hover:text-white transition">Search</a></li>
        <li><a href="#" class="motion-hover-lift inline-flex hover:text-white transition">Brands</a></li>
        <li><a href="#" class="motion-hover-lift inline-flex hover:text-white transition">Privacy policy</a></li>
      </ul>
    </div>

    <div class="motion-reveal">
      <h4 class="text-white font-semibold mb-4 text-lg md:text-xl">Reach us</h4>
      <ul class="space-y-6 text-gray-400">
        <li class="flex items-center gap-2">
          <img src={emailIcon} alt="Email" width="20" height="20" class="w-5 h-5" />
          <span>support@trueview.health</span>
        </li>
        <li class="flex items-center gap-2">
          <img src={mobileIcon} alt="Phone" width="16" height="20" class="w-4 h-5" />
          <span>+1(858)568-1132</span>
        </li>
        <li class="flex items-center gap-2">
          <img src={locationIcon} alt="Location" width="20" height="20" class="w-5 h-5" />
          <span>100 S Congress Ave, STE 2000<br />Austin, TX</span>
        </li>
      </ul>
    </div>

    <div class="motion-reveal motion-reveal-right">
      <h4 class="text-white font-semibold mb-4">Stay up to date</h4>
      <div class="relative">
        <input
          type="email"
          placeholder="Your email address"
          class="motion-hover-lift w-full bg-gray-700 border border-white/10 rounded-lg py-3 px-4 pr-10 text-gray-900 outline-none focus:border-trueview-blue placeholder:text-gray-500"
        />
        <span class="absolute right-3 top-1/2 -translate-y-1/2">
          <img src={sendIcon} alt="Enviar" width="20" height="20" class="w-5 h-5" />
        </span>
      </div>
    </div>
  </footer>
</section>
