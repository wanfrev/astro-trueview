---
import Ellipse2 from '../assets/images/Ellipse2.png';
import Ellipse3 from '../assets/images/Ellipse3.png';
import Ellipse4 from '../assets/images/Ellipse4.png';
import Ellipse5 from '../assets/images/backg5.webp';
import Ellipse6 from '../assets/images/Ellipse6.png';
import Ellipse7 from '../assets/images/Ellipse7.png';
import { Image } from 'astro:assets';

const bgHeroSizes = '(max-width: 768px) 980px, (max-width: 1280px) 1320px, 1500px';
const bgFailsSizes = '(max-width: 768px) 880px, (max-width: 1280px) 1120px, 1300px';
const bgLabSizes = '(max-width: 768px) 620px, (max-width: 1280px) 760px, 900px';
const bgGoodBadSizes = '(max-width: 768px) 980px, (max-width: 1280px) 1220px, 1480px';
const bgGoodBad2Sizes = '(max-width: 768px) 620px, (max-width: 1280px) 760px, 900px';
const bgWaitMoreSizes = '(max-width: 768px) 860px, (max-width: 1280px) 1080px, 1340px';
---

<style is:inline>
  /*
    Ajustes rápidos: modifica los valores de abajo (en px o %) para mover cada ellipse.
    - --bg-*-left / --bg-*-right: posición horizontal base (usa % o px, con signo si es necesario)
    - --bg-*-dx: desplazamiento horizontal adicional (px)
    - --bg-*-dy: desplazamiento vertical adicional (px)
    Los valores calculados combinan la posición dinámica (desde JS) y estos offsets.
  */
  :root{
    --bg-hero-left: 6%;
    --bg-hero-dx: -140px;
    --bg-hero-dy: -170px;

    /* Tamaño por defecto (ajusta ancho/alto aquí) */
    --bg-hero-w: 1500px;
    --bg-hero-h: auto;

    --bg-fails-left: -12%;
    --bg-fails-dx: 180px;
    --bg-fails-dy: -470px;
    --bg-fails-w: 1300px;
    --bg-fails-h: auto;

    --bg-lab-right: -12%;
    --bg-lab-dx: 120px;
    --bg-lab-dy: -460px;
    --bg-lab-w: 900px;
    --bg-lab-h: auto;

    --bg-good-bad-right: -10%;
    --bg-good-bad-dx: 180px;
    --bg-good-bad-dy: -330px;
    --bg-good-bad-w: 1480px;
    --bg-good-bad-h: auto;

    --bg-good-bad-2-left: -8%;
    --bg-good-bad-2-dx: 780px;
    --bg-good-bad-2-dy: -220px;
    --bg-good-bad-2-w: 900px;
    --bg-good-bad-2-h: auto;

    --bg-wait-more-right: -16%;
    --bg-wait-more-dx: 120px;
    --bg-wait-more-dy: -420px;
    --bg-wait-more-w: 1340px;
    --bg-wait-more-h: auto;
  }

  @media (min-width: 1024px) and (max-width: 1535px) {
    :root {
      --bg-hero-w: 1320px;
      --bg-hero-dx: -110px;

      --bg-fails-w: 1120px;
      --bg-fails-left: 50%;
      --bg-fails-dx: -50%;
      --bg-fails-dy: -380px;

      --bg-lab-w: 760px;
      --bg-lab-dx: 80px;
      --bg-lab-dy: -360px;

      --bg-good-bad-w: 1220px;
      --bg-good-bad-dx: 110px;
      --bg-good-bad-dy: -240px;

      --bg-good-bad-2-w: 760px;
      --bg-good-bad-2-dx: 620px;

      --bg-wait-more-w: 1080px;
      --bg-wait-more-dx: 80px;
      --bg-wait-more-dy: -340px;
    }
  }

  @media (max-width: 1023px) {
    :root {
      --bg-hero-w: 980px;
      --bg-hero-dx: -80px;
      --bg-hero-dy: -120px;

      --bg-fails-w: 880px;
      --bg-fails-left: 50%;
      --bg-fails-dx: -50%;
      --bg-fails-dy: -240px;

      --bg-lab-w: 620px;
      --bg-lab-dx: 40px;
      --bg-lab-dy: -260px;

      --bg-good-bad-w: 980px;
      --bg-good-bad-dx: 50px;
      --bg-good-bad-dy: -160px;

      --bg-good-bad-2-w: 620px;
      --bg-good-bad-2-dx: 360px;
      --bg-good-bad-2-dy: -150px;

      --bg-wait-more-w: 860px;
      --bg-wait-more-dx: 40px;
      --bg-wait-more-dy: -220px;
    }
  }

  .bg-ellipse {
    animation: none;
  }

  .bg-ellipse-1,
  .bg-ellipse-3 {
    will-change: transform;
    animation-iteration-count: infinite;
    animation-direction: alternate;
    animation-timing-function: ease-in-out;
  }

  .bg-ellipse-1 { animation-name: bgDriftA; animation-duration: 22s; }
  .bg-ellipse-3 { animation-name: bgDriftC; animation-duration: 26s; }

  @keyframes bgDriftA {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(-8px, 6px, 0) scale(1.008); }
  }

  @keyframes bgDriftB {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(6px, -5px, 0) scale(1.006); }
  }

  @keyframes bgDriftC {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(-7px, -6px, 0) scale(1.007); }
  }

  @media (max-width: 1023px) {
    .bg-ellipse {
      animation: none !important;
      transform: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-ellipse {
      animation: none !important;
      transform: none !important;
    }
  }
</style>

<div aria-hidden="true" class="absolute inset-x-0 top-0 -z-10 pointer-events-none overflow-hidden" style="height: var(--bg-canvas-height, 3000px)">
  <!-- Degradado de Hero -->
  <Image
    src={Ellipse2}
    alt=""
    id="bg-hero"
    loading="eager"
    fetchpriority="high"
    format="webp"
    quality={52}
    widths={[640, 960, 1280, 1600]}
    sizes={bgHeroSizes}
    decoding="async"
    class="bg-ellipse bg-ellipse-1 absolute max-w-none mix-blend-screen blur-[36px] opacity-100"
    style="top: calc(var(--bg-hero-top, 96px) + var(--bg-hero-dy, 0px)); left: calc(var(--bg-hero-left, 6%) + var(--bg-hero-dx, 0px)); width: var(--bg-hero-w, 1200px); height: var(--bg-hero-h, auto);"
  />

  <!-- Degradado de The Fails -->
  <Image
    src={Ellipse3}
    alt=""
    id="bg-fails"
    loading="lazy"
    format="webp"
    quality={52}
    widths={[640, 960, 1280, 1440]}
    sizes={bgFailsSizes}
    decoding="async"
    class="bg-ellipse bg-ellipse-2 absolute max-w-none mix-blend-screen blur-[18px] opacity-95"
    style="top: calc(var(--bg-fails-top, 1500px) + var(--bg-fails-dy, 0px)); left: calc(var(--bg-fails-left, -12%) + var(--bg-fails-dx, 0px)); width: var(--bg-fails-w, 980px); height: var(--bg-fails-h, auto);"
  />

  <!-- Degradado de LabTesting -->
  <Image
    src={Ellipse4}
    alt=""
    id="bg-lab"
    loading="lazy"
    format="webp"
    quality={50}
    widths={[480, 720, 960, 1200]}
    sizes={bgLabSizes}
    decoding="async"
    class="bg-ellipse bg-ellipse-3 absolute max-w-none mix-blend-screen opacity-95 blur-[8px]"
    style="top: calc(var(--bg-lab-top, 2250px) + var(--bg-lab-dy, 0px)); right: calc(var(--bg-lab-right, -12%) + var(--bg-lab-dx, 0px)); width: var(--bg-lab-w, 980px); height: var(--bg-lab-h, auto);"
  />

  <!-- Degradado de GoodAndBadfirst -->
  <Image
    src={Ellipse5}
    alt=""
    id="bg-good-bad"
    loading="lazy"
    format="webp"
    quality={50}
    widths={[640, 960, 1280, 1536]}
    sizes={bgGoodBadSizes}
    decoding="async"
    class="bg-ellipse bg-ellipse-4 absolute max-w-none mix-blend-screen opacity-95 blur-[64px]"
    style="top: calc(var(--bg-good-bad-top, 2900px) + var(--bg-good-bad-dy, 0px)); right: calc(var(--bg-good-bad-right, -10%) + var(--bg-good-bad-dx, 0px)); width: var(--bg-good-bad-w, 920px); height: var(--bg-good-bad-h, auto);"
  />

  <!-- Degradado de GoodAndBad -->
  <Image
    src={Ellipse6}
    alt=""
    id="bg-good-bad-2"
    loading="lazy"
    format="webp"
    quality={50}
    widths={[480, 720, 960, 1200]}
    sizes={bgGoodBad2Sizes}
    decoding="async"
    class="bg-ellipse bg-ellipse-5 absolute max-w-none mix-blend-screen opacity-90 blur-[64px]"
    style="top: calc(var(--bg-good-bad-2-top, 3600px) + var(--bg-good-bad-2-dy, 0px)); left: calc(var(--bg-good-bad-2-left, -8%) + var(--bg-good-bad-2-dx, 0px)); width: var(--bg-good-bad-2-w, 980px); height: var(--bg-good-bad-2-h, auto);"
  />

  <!-- Degradado de WaitTheresMore -->
  <Image
    src={Ellipse7}
    alt=""
    id="bg-wait-more"
    loading="lazy"
    format="webp"
    quality={50}
    widths={[640, 960, 1280, 1536]}
    sizes={bgWaitMoreSizes}
    decoding="async"
    class="bg-ellipse bg-ellipse-6 absolute max-w-none mix-blend-screen opacity-95"
    style="top: calc(var(--bg-wait-more-top, 4300px) + var(--bg-wait-more-dy, 0px)); right: calc(var(--bg-wait-more-right, -16%) + var(--bg-wait-more-dx, 0px)); width: var(--bg-wait-more-w, 940px); height: var(--bg-wait-more-h, auto);"
  />
</div>

<script is:inline>
  (() => {
    let rafId = 0;

    const scheduleUpdate = () => {
      if (rafId) {
        return;
      }

      rafId = window.requestAnimationFrame(() => {
        rafId = 0;
        updateBackgroundLayout();
      });
    };

    function updateBackgroundLayout() {
      const doc = document.documentElement;
      const body = document.body;

      const canvasHeight = Math.max(body.scrollHeight, doc.scrollHeight, body.offsetHeight, doc.offsetHeight);
      doc.style.setProperty('--bg-canvas-height', `${canvasHeight}px`);

      const hero = document.querySelector('section[data-bg="hero"]');
      const fails = document.querySelector('section[data-bg="fails"]');
      const lab = document.querySelector('section[data-bg="lab"]');
      const goodBad = document.querySelector('section[data-bg="good-bad"]');
      const goodBad2 = document.querySelector('section[data-bg="good-bad-2"]');
      const waitMore = document.querySelector('section[data-bg="wait-more"]');

      if (hero) {
        const heroTop = hero.offsetTop + 96;
        doc.style.setProperty('--bg-hero-top', `${heroTop}px`);
      }

      if (fails) {
        const failsTop = fails.offsetTop + 40;
        doc.style.setProperty('--bg-fails-top', `${failsTop}px`);
      }

      if (lab) {
        const labTop = lab.offsetTop + 40;
        doc.style.setProperty('--bg-lab-top', `${labTop}px`);
      }

      if (goodBad) {
        const goodBadTop = goodBad.offsetTop + 110;
        doc.style.setProperty('--bg-good-bad-top', `${goodBadTop}px`);
      }

      if (goodBad2) {
        const goodBad2Top = goodBad2.offsetTop + 20;
        doc.style.setProperty('--bg-good-bad-2-top', `${goodBad2Top}px`);
      }

      if (waitMore) {
        const waitMoreTop = waitMore.offsetTop + 120;
        doc.style.setProperty('--bg-wait-more-top', `${waitMoreTop}px`);
      }
    }

    if (document.readyState === 'loading') {
      window.addEventListener('DOMContentLoaded', scheduleUpdate, { once: true });
    } else {
      scheduleUpdate();
    }

    window.addEventListener('load', scheduleUpdate, { once: true });
    window.addEventListener('resize', scheduleUpdate, { passive: true });
    window.addEventListener('orientationchange', scheduleUpdate, { passive: true });
    window.addEventListener('pageshow', scheduleUpdate);

    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(scheduleUpdate);
    }

    window.setTimeout(scheduleUpdate, 350);
  })();
</script>
