---
import TopProducts from "../assets/images/topproducts.png";
import RequestATest from "../assets/images/requestatest.png";
import CumulativeEffect from "../assets/images/cumulativeeffect.png";
import WeeklyCategory from "../assets/images/weeklycategory.png";
import { Image } from "astro:assets";

const featureLabels = [
  { text: 'Top Products', color: 'text-blue-400' },
  { text: 'Request a Test', color: 'text-red-400' },
  { text: 'Cumulative Effect', color: 'text-blue-500' },
  { text: 'Weekly Category', color: 'text-red-500' }
];

const featureCards = [
  {
    id: 'feature-0',
    title: 'Top Products',
    description: 'A comprehensive catalog showcasing top industry brands and products, each verified through laboratory testing.',
    image: TopProducts,
    widthClass: 'w-[90vw] lg:w-[82vw] 2xl:w-[1050px]'
  },
  {
    id: 'feature-1',
    title: 'Request a Test',
    description: "Don't see your product? Request a test and we'll get it done for you.",
    image: RequestATest,
    widthClass: 'w-[86vw] lg:w-[62vw] 2xl:w-[620px]'
  },
  {
    id: 'feature-2',
    title: 'Cumulative Effect',
    description: 'Understand cumulative exposure across repeated product use.',
    image: CumulativeEffect,
    widthClass: 'w-[90vw] lg:w-[76vw] 2xl:w-[850px]'
  },
  {
    id: 'feature-3',
    title: 'Weekly Category',
    description: 'Fresh results every week. New products tested and results updated regularly.',
    image: WeeklyCategory,
    widthClass: 'w-[90vw] lg:w-[82vw] 2xl:w-[1050px]'
  }
];
---

<section data-bg="features" class="section-shell py-24 lg:py-28 xl:py-32 bg-[#050505]/40 text-white overflow-hidden relative">
  <div class="content-shell">
    
    <div class="text-center mb-16">
      <h2 class="text-5xl lg:text-[62px] xl:text-[80px] 2xl:text-[90px] font-bold tracking-tighter mb-10">Features</h2>

      <div class="flex flex-wrap justify-center gap-3">
        {featureLabels.map((label, index) => (
          <button 
            data-target={`feature-${index}`}
            class="feature-btn flex items-center gap-2 px-5 lg:px-6 py-3 rounded-full border border-white/10 bg-white/5 text-sm font-semibold tracking-wide transition-all hover:bg-white/15 active:scale-95"
          >
            <span class={`${label.color} text-lg`}>✦</span>
            {label.text}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div 
    id="features-container"
    class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-12 w-full"
    style="--pad: max(1.5rem, calc((100vw - 1440px) / 2 + 3rem)); padding-left: var(--pad); padding-right: 1.5rem; scroll-padding-left: var(--pad); scrollbar-width: none; -ms-overflow-style: none;"
  >
    {featureCards.map((card) => (
      <article 
        id={card.id}
        class={`group relative flex flex-col overflow-hidden rounded-[40px] border border-white/5 bg-[#0D0D12] pt-12 px-8 lg:px-10 xl:px-12 h-[550px] lg:h-[760px] xl:h-[860px] shrink-0 snap-start transition-all duration-500 hover:border-white/10 ${card.id === 'feature-0' ? 'lg:-ml-2 2xl:-ml-6' : ''} ${card.widthClass}`}
      >
        <div class="max-w-[400px] text-left z-20 relative">
          <h3 class="text-3xl lg:text-[32px] xl:text-[34px] font-bold mb-4 tracking-tight leading-tight">{card.title}</h3>
          <p class="text-[16px] lg:text-[17px] leading-relaxed text-gray-400 font-medium opacity-90">
            {card.description}
          </p>
        </div>

        <div class="absolute inset-0 flex items-end justify-center pointer-events-none pt-24">
          <div class="absolute bottom-[-10%] h-[160px] lg:h-[200px] w-full bg-blue-500/10 blur-[70px] lg:blur-[100px] rounded-full"></div>
          
          <Image 
            src={card.image} 
            alt={card.title} 
            class="w-full h-[70%] lg:h-[74%] xl:h-[77%] object-contain object-bottom transition-transform duration-700 ease-out group-hover:scale-[1.05]" 
          />
        </div>
      </article>
      ))}
    </div>
</section>

<style>
  /* Ocultar scrollbar para Chrome, Safari y Opera */
  #features-container::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  (function(){
    const container = document.getElementById('features-container');
    const buttons = document.querySelectorAll('.feature-btn');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-target');
        const targetElement = document.getElementById(targetId);

        if (container && targetElement) {
          // Calculamos la posición para centrar la card
          const containerHalfWidth = container.offsetWidth / 2;
          const elementHalfWidth = targetElement.offsetWidth / 2;
          const targetScrollPos = targetElement.offsetLeft - containerHalfWidth + elementHalfWidth;

          container.scrollTo({
            left: targetScrollPos,
            behavior: 'smooth'
          });
        }
      });
    });
  })();
</script>
