---
import TopProducts from "../assets/images/topproducts.png";
import RequestATest from "../assets/images/requestatest.png";
import CumulativeEffect from "../assets/images/cumulativeeffect.png";
import WeeklyCategory from "../assets/images/weeklycategory.png";
import { Image } from "astro:assets";

const featureLabels = [
  { text: 'Top Products', color: 'text-blue-400' },
  { text: 'Request a Test', color: 'text-red-400' },
  { text: 'Cumulative Effect', color: 'text-blue-500' },
  { text: 'Weekly Category', color: 'text-red-500' }
];

const featureCards = [
  {
    id: 'feature-0',
    title: 'Top Products',
    description: 'A comprehensive catalog showcasing top industry brands and products, each verified through laboratory testing.',
    image: TopProducts,
    widthClass: 'w-[88vw] sm:w-[84vw] lg:w-[82vw] 2xl:w-[1050px]'
  },
  {
    id: 'feature-1',
    title: 'Request a Test',
    description: "Don't see your product? Request a test and we'll get it done for you.",
    image: RequestATest,
    widthClass: 'w-[88vw] sm:w-[84vw] lg:w-[62vw] 2xl:w-[620px]'
  },
  {
    id: 'feature-2',
    title: 'Cumulative Effect',
    description: 'Understand cumulative exposure across repeated product use.',
    image: CumulativeEffect,
    widthClass: 'w-[88vw] sm:w-[84vw] lg:w-[76vw] 2xl:w-[850px]'
  },
  {
    id: 'feature-3',
    title: 'Weekly Category',
    description: 'Fresh results every week. New products tested and results updated regularly.',
    image: WeeklyCategory,
    widthClass: 'w-[88vw] sm:w-[84vw] lg:w-[82vw] 2xl:w-[1050px]'
  }
];
---

<section id="features-section" data-bg="features" class="section-shell py-16 sm:py-20 lg:py-28 xl:py-32 bg-[#050505]/40 text-white overflow-hidden relative features-anim">
  <div class="content-shell">
    
    <div class="text-center mb-10 sm:mb-14 lg:mb-16">
      <h2 class="features-title text-[42px] sm:text-5xl lg:text-[62px] xl:text-[80px] 2xl:text-[90px] font-bold tracking-tighter mb-7 sm:mb-10">Features</h2>

      <div class="flex flex-wrap justify-center gap-2.5 sm:gap-3">
        {featureLabels.map((label, index) => (
          <button 
            data-target={`feature-${index}`}
            class="feature-btn feature-chip flex items-center gap-2 px-4 sm:px-5 lg:px-6 py-2.5 sm:py-3 rounded-full border border-white/10 bg-white/5 text-[13px] sm:text-sm font-semibold tracking-wide transition-all hover:bg-white/15 active:scale-95"
            style={`--i:${index};`}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            <span class={`${label.color} text-lg`}>✦</span>
            {label.text}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div 
    id="features-container"
    class="flex gap-4 sm:gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-8 sm:pb-12 w-full"
    style="--pad: max(1rem, calc((100vw - 1440px) / 2 + 3rem)); padding-left: var(--pad); padding-right: 1rem; scroll-padding-left: var(--pad); scrollbar-width: none; -ms-overflow-style: none;"
  >
    {featureCards.map((card) => (
      <article 
        id={card.id}
        class={`feature-card group relative flex flex-col overflow-hidden rounded-[30px] sm:rounded-[36px] lg:rounded-[40px] border border-white/5 bg-[#0D0D12] pt-7 sm:pt-9 lg:pt-12 px-5 sm:px-7 lg:px-10 xl:px-12 h-[460px] sm:h-[530px] lg:h-[760px] xl:h-[860px] shrink-0 snap-start transition-all duration-500 hover:border-white/10 ${card.id === 'feature-0' ? 'lg:-ml-2 2xl:-ml-6' : ''} ${card.widthClass}`}
        style={`--i:${Number(card.id.split('-')[1])};`}
      >
        <div class="feature-content max-w-[340px] sm:max-w-[400px] text-left z-20 relative">
          <h3 class="text-[28px] sm:text-3xl lg:text-[32px] xl:text-[34px] font-bold mb-3 sm:mb-4 tracking-tight leading-tight">{card.title}</h3>
          <p class="text-[14px] sm:text-[16px] lg:text-[17px] leading-relaxed text-gray-400 font-medium opacity-90 max-w-[34ch]">
            {card.description}
          </p>
        </div>

        <div class="absolute inset-0 flex items-end justify-center pointer-events-none pt-20 sm:pt-24">
          <div class="absolute bottom-[-10%] h-[130px] sm:h-[160px] lg:h-[200px] w-full bg-blue-500/10 blur-[55px] sm:blur-[70px] lg:blur-[100px] rounded-full"></div>

          <div class="feature-image-wrap w-full h-[60%] sm:h-[67%] lg:h-[74%] xl:h-[77%]">
            <Image 
              src={card.image} 
              alt={card.title} 
              loading="lazy"
              decoding="async"
              class="feature-image feature-phone w-full h-full object-contain object-bottom transition-transform duration-700 ease-out group-hover:scale-[1.05]" 
            />
          </div>
        </div>
      </article>
      ))}
    </div>
</section>

<style>
  /* Ocultar scrollbar para Chrome, Safari y Opera */
  #features-container::-webkit-scrollbar {
    display: none;
  }

  @keyframes featureFadeUp {
    0% {
      opacity: 0;
      transform: translate3d(0, 26px, 0);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes featureImageFloat {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(0, -10px, 0);
    }
  }

  @keyframes featureButtonPop {
    0% {
      transform: scale(1);
    }
    40% {
      transform: scale(0.96);
    }
    100% {
      transform: scale(1.04);
    }
  }

  @keyframes featureButtonRipple {
    0% {
      opacity: 0.45;
      transform: translate(-50%, -50%) scale(0.2);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(1.15);
    }
  }

  @keyframes featureCardNudge {
    0% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    45% {
      transform: translate3d(0, -10px, 0) scale(1.015);
    }
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes featureContentIn {
    0% {
      opacity: 0;
      transform: translate3d(0, 22px, 0) scale(0.98);
    }
    56% {
      opacity: 1;
      transform: translate3d(0, -3px, 0) scale(1.01);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes featurePhoneIn {
    0% {
      opacity: 0;
      transform: translate3d(0, 36px, 0) scale(0.92) rotate(-0.9deg);
      filter: drop-shadow(0 0 0 rgb(56 189 248 / 0));
    }
    58% {
      opacity: 1;
      transform: translate3d(0, -5px, 0) scale(1.03) rotate(0.4deg);
      filter: drop-shadow(0 10px 18px rgb(56 189 248 / 0.2));
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
      filter: drop-shadow(0 6px 14px rgb(56 189 248 / 0.14));
    }
  }

  .features-title,
  .feature-chip,
  .feature-card {
    opacity: 0;
    transform: translate3d(0, 26px, 0);
  }

  .features-anim.is-visible .features-title {
    animation: featureFadeUp 700ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  .features-anim.is-visible .feature-chip {
    animation: featureFadeUp 650ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
    animation-delay: calc(120ms + (var(--i) * 90ms));
  }

  .features-anim.is-visible .feature-card {
    animation: featureFadeUp 800ms cubic-bezier(0.16, 0.84, 0.32, 1) both;
    animation-delay: calc(220ms + (var(--i) * 110ms));
  }

  .features-anim.is-visible .feature-image-wrap {
    animation: featureImageFloat 6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 280ms);
  }

  .feature-btn[aria-pressed='true'] {
    background: rgb(255 255 255 / 0.16);
    border-color: rgb(255 255 255 / 0.28);
    box-shadow: 0 0 0 1px rgb(255 255 255 / 0.08) inset;
  }

  .feature-btn {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .feature-btn::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 220%;
    aspect-ratio: 1 / 1;
    border-radius: 9999px;
    background: radial-gradient(circle, rgb(255 255 255 / 0.34) 0%, rgb(255 255 255 / 0) 62%);
    transform: translate(-50%, -50%) scale(0.2);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  .feature-btn > * {
    position: relative;
    z-index: 1;
  }

  .feature-btn.is-clicking {
    animation: featureButtonPop 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .feature-btn.is-clicking::after {
    animation: featureButtonRipple 420ms ease-out;
  }

  .feature-card.is-nudging {
    animation: featureCardNudge 480ms cubic-bezier(0.2, 0.85, 0.22, 1);
  }

  .feature-card.is-activating .feature-content {
    animation: featureContentIn 540ms cubic-bezier(0.18, 0.9, 0.24, 1) both;
  }

  .feature-card.is-activating .feature-phone {
    animation: featurePhoneIn 660ms cubic-bezier(0.15, 0.92, 0.24, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .features-title,
    .feature-chip,
    .feature-card {
      opacity: 1;
      transform: none;
      animation: none !important;
    }

    .feature-image-wrap {
      animation: none !important;
    }

    .feature-btn.is-clicking,
    .feature-btn.is-clicking::after,
    .feature-card.is-nudging,
    .feature-card.is-activating .feature-content,
    .feature-card.is-activating .feature-phone {
      animation: none !important;
    }
  }
</style>

<script is:inline>
  (function(){
    const section = document.getElementById('features-section');
    const container = document.getElementById('features-container');
    const buttons = document.querySelectorAll('.feature-btn');
    const cards = document.querySelectorAll('.feature-card');

    const getClampedScrollLeft = (targetElement) => {
      if (!container || !targetElement) return 0;

      const containerHalfWidth = container.offsetWidth / 2;
      const elementHalfWidth = targetElement.offsetWidth / 2;
      const rawScrollLeft = targetElement.offsetLeft - containerHalfWidth + elementHalfWidth;
      const maxScrollLeft = Math.max(0, container.scrollWidth - container.clientWidth);

      return Math.max(0, Math.min(rawScrollLeft, maxScrollLeft));
    };

    const scrollToCard = (targetId, behavior = 'smooth') => {
      if (!container || !targetId) return null;

      const targetElement = document.getElementById(targetId);
      if (!targetElement) return null;

      container.scrollTo({
        left: getClampedScrollLeft(targetElement),
        behavior,
      });

      return targetElement;
    };

    const setActiveButton = (activeButton) => {
      buttons.forEach((button) => {
        button.setAttribute('aria-pressed', button === activeButton ? 'true' : 'false');
      });
    };

    const triggerClickAnimation = (button, targetElement) => {
      if (button) {
        button.classList.remove('is-clicking');
        void button.offsetWidth;
        button.classList.add('is-clicking');

        window.setTimeout(() => {
          button.classList.remove('is-clicking');
        }, 420);
      }

      if (targetElement) {
        targetElement.classList.remove('is-nudging');
        void targetElement.offsetWidth;
        targetElement.classList.add('is-nudging');

        targetElement.classList.remove('is-activating');
        void targetElement.offsetWidth;
        targetElement.classList.add('is-activating');

        window.setTimeout(() => {
          targetElement.classList.remove('is-nudging');
        }, 500);

        window.setTimeout(() => {
          targetElement.classList.remove('is-activating');
        }, 740);
      }
    };

    if (section) {
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          ([entry]) => {
            if (!entry.isIntersecting) return;
            section.classList.add('is-visible');
            observer.disconnect();
          },
          {
            threshold: 0.18,
          },
        );

        observer.observe(section);
      } else {
        section.classList.add('is-visible');
      }
    }

    const initialActiveButton = document.querySelector('.feature-btn[aria-pressed="true"]');
    const initialTargetId = initialActiveButton?.getAttribute('data-target');

    if (initialTargetId) {
      // Ejecutamos varias veces para cubrir hidratación y carga de imágenes en móvil.
      window.requestAnimationFrame(() => scrollToCard(initialTargetId, 'auto'));
      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => scrollToCard(initialTargetId, 'auto'));
      });

      window.addEventListener('load', () => {
        scrollToCard(initialTargetId, 'auto');
      });
    }

    let resizeTimer;
    window.addEventListener('resize', () => {
      if (!initialTargetId) return;
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        scrollToCard(initialTargetId, 'auto');
      }, 140);
    });

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-target');
        const targetElement = scrollToCard(targetId);

        if (container && targetElement) {
          setActiveButton(button);
          triggerClickAnimation(button, targetElement);
        }
      });
    });

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        const targetId = card.getAttribute('id');
        if (!targetId) return;

        const relatedButton = document.querySelector(`.feature-btn[data-target="${targetId}"]`);
        const targetElement = scrollToCard(targetId);

        if (relatedButton) {
          setActiveButton(relatedButton);
        }

        triggerClickAnimation(relatedButton, targetElement || card);
      });
    });
  })();
</script>
