---
import TopProducts from "../assets/images/topproducts.png";
import RequestATest from "../assets/images/requestatest.png";
import CumulativeEffect from "../assets/images/cumulativeeffect.png";
import WeeklyCategory from "../assets/images/weeklycategory.png";
import { Image } from "astro:assets";

const featureLabels = [
  { text: 'Top Products', color: 'text-blue-400' },
  { text: 'Request a Test', color: 'text-red-400' },
  { text: 'Cumulative Effect', color: 'text-blue-500' },
  { text: 'Weekly Category', color: 'text-red-500' }
];

const featureCards = [
  {
    id: 'feature-0',
    title: 'Top Products',
    description: 'A comprehensive catalog showcasing top industry brands and products, each verified through laboratory testing.',
    image: TopProducts,
    // Card más ancha para los dos teléfonos
    widthClass: 'w-[90vw] md:w-[950px]'
  },
  {
    id: 'feature-1',
    title: 'Request a Test',
    description: "Don't see your product? Request a test and we'll get it done for you.",
    image: RequestATest,
    widthClass: 'w-[85vw] md:w-[500px]'
  },
  {
    id: 'feature-2',
    title: 'Cumulative Effect',
    description: 'Understand cumulative exposure across repeated product use.',
    image: CumulativeEffect,
    // Card intermedia
    widthClass: 'w-[90vw] md:w-[750px]'
  },
  {
    id: 'feature-3',
    title: 'Weekly Category',
    description: 'Fresh results every week. New products tested and results updated regularly.',
    image: WeeklyCategory,
    // Card ancha para los dos teléfonos
    widthClass: 'w-[90vw] md:w-[950px]'
  }
];
---

<section class="py-24 md:py-32 bg-[#050505] text-white overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6">
    
    <div class="text-center mb-16">
      <h2 class="text-5xl md:text-[90px] font-bold tracking-tighter mb-10">Features</h2>

      <div class="flex flex-wrap justify-center gap-3">
        {featureLabels.map((label, index) => (
          <button 
            data-target={`feature-${index}`}
            class="feature-btn flex items-center gap-2 px-6 py-3 rounded-full border border-white/10 bg-white/5 text-sm font-semibold tracking-wide transition-all hover:bg-white/15 active:scale-95"
          >
            <span class={`${label.color} text-lg`}>✦</span>
            {label.text}
          </button>
        ))}
      </div>
    </div>

    <div 
      id="features-container"
      class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-12 -mx-6 px-6"
      style="scrollbar-width: none; -ms-overflow-style: none;"
    >
      {featureCards.map((card) => (
        <article 
          id={card.id}
          class={`group relative flex flex-col justify-between overflow-hidden rounded-[40px] border border-white/5 bg-[#0D0D12] pt-10 px-8 md:px-10 min-h-[580px] shrink-0 snap-center transition-all duration-500 hover:border-white/10 ${card.widthClass}`}
        >
          
          <div class="max-w-[360px] text-left">
            <h3 class="text-2xl md:text-[28px] font-bold mb-3 tracking-tight">{card.title}</h3>
            <p class="text-[15px] md:text-[16px] leading-relaxed text-gray-400 font-medium opacity-80">
              {card.description}
            </p>
          </div>

          <div class="mt-8 relative flex justify-center items-end h-full">
            <div class="absolute bottom-[-20px] h-[150px] w-full bg-blue-500/5 blur-[80px] rounded-full pointer-events-none"></div>
            
            <Image 
              src={card.image} 
              alt={card.title} 
              class="relative z-10 w-full h-auto object-contain object-bottom transition-transform duration-700 ease-out group-hover:scale-[1.03]" 
            />
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Ocultar scrollbar para Chrome, Safari y Opera */
  #features-container::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  (function(){
    const container = document.getElementById('features-container');
    const buttons = document.querySelectorAll('.feature-btn');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-target');
        const targetElement = document.getElementById(targetId);

        if (container && targetElement) {
          // Calculamos la posición para centrar la card
          const containerHalfWidth = container.offsetWidth / 2;
          const elementHalfWidth = targetElement.offsetWidth / 2;
          const targetScrollPos = targetElement.offsetLeft - containerHalfWidth + elementHalfWidth;

          container.scrollTo({
            left: targetScrollPos,
            behavior: 'smooth'
          });
        }
      });
    });
  })();
</script>
