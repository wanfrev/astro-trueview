---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Trueview | Lab Tested Products' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="selection:bg-trueview-blue/30">
		<slot />
	</body>
</html>
