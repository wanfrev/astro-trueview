---
import '../styles/global.css';
import Background from '../components/Background.astro';
import HeroGlow from '../assets/images/Ellipse2.png';
import HeroPhone from '../assets/images/phonecaution1.png';
import HeroUnion from '../assets/icons/Union.svg';

interface Props {
	title?: string;
}

const { title = 'Trueview | Lab Tested Products' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preload" as="image" href={HeroGlow.src} fetchpriority="high" />
		<link rel="preload" as="image" href={HeroPhone.src} fetchpriority="high" />
		<link rel="preload" as="image" href={HeroUnion.src} fetchpriority="high" />
		<title>{title}</title>
	</head>
	<body class="selection:bg-trueview-blue/30">
		<Background />
		<slot />
	</body>
</html>
